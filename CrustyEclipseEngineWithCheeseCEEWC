-- ===== HELPER FUNCTIONS =====
local function GetToolModel(character)
    if not character then return nil end
    for _, obj in ipairs(character:GetChildren()) do
        if obj:IsA("Model") and obj:GetAttribute("StorageItemId") then
            return obj
        end
    end
    return character:FindFirstChildWhichIsA("Model")
end

local function GetBulletOrigin(tool)
    if not tool then return nil end
    local handle = tool:FindFirstChild("Handle")
    if handle then
        return handle:FindFirstChild("BulletOrigin") or handle
    end
    return nil
end

local function isValidBarricade(part)
    local config = BarricadeNames[part.Name]
    if not config then return false end
    if config.exact and not config.requireHealth and not config.requireAnchored then
        return true
    end
    if config.requireHealth then
        local hasHealth = part:FindFirstChild("Health") or part:FindFirstChild("HP")
        if not hasHealth then return false end
    end
    if config.requireAnchored then
        if not part.Anchored then return false end
    end
    return true
end

