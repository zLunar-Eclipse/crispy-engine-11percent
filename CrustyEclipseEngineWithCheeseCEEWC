-- ===== MAIN LOOP =====
renderConnection = RunService.RenderStepped:Connect(function(delta)
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end

    local hrp = character.HumanoidRootPart
    local tool = GetToolModel(character)

    local closest = nil
    local shortest = math.huge
    local isBanditTarget = false
    local targetType = "NPC"

    -- ===== TARGET SCANNING (Unified: NPCs + Barricades) =====
    if tick() - LastTargetUpdate > 0.12 then
        LastTargetUpdate = tick()
        
        if not cachedEntityFolder then
            cachedEntityFolder = Workspace:FindFirstChild("Entity")
        end
        if cachedEntityFolder then
            for _, v in ipairs(cachedEntityFolder:GetChildren()) do
                if v:FindFirstChild("Head") then
                    local nameLower = v.Name:lower()
                    local isValid = false
                    if v:FindFirstChild("Zombie") then 
                        isValid = true
                    elseif nameLower:find("hector") or v.Name == "Hector Shot" or v.Name == "HectorShot" then 
                        isValid = true
                    elseif nameLower:find("klyde") or v.Name == "Klyde" then 
                        isValid = true
                    elseif nameLower:find("karl") or v.Name == "Karl" then 
                        isValid = true
                    elseif v.Name == "ZomborgPrime" or nameLower:find("zomborg") then 
                        isValid = true
                    end
                    if isValid then
                        local hum = v:FindFirstChild("Humanoid") or v:FindFirstChildWhichIsA("Humanoid")
                        if hum and hum.Health > 0 then
                            local dist = (v.Head.Position - hrp.Position).Magnitude
                            if dist < shortest then
                                shortest = dist
                                closest = v
                                isBanditTarget = false
                                targetType = "NPC"
                            end
                        end
                    end
                end
            end
        end

        if (tick() - LastBanditScan > 0.5) then
            LastBanditScan = tick()
            local function EvaluateBandit(obj)
                local hum = obj:FindFirstChild("Humanoid") or obj:FindFirstChildWhichIsA("Humanoid")
                local head = obj:FindFirstChild("Head")
                if hum and hum.Health > 0 and head then
                    local dist = (head.Position - hrp.Position).Magnitude
                    if dist < shortest then
                        shortest = dist
                        closest = obj
                        isBanditTarget = true
                        targetType = "NPC"
                    end
                end
            end
            local checked = false
            for _, obj in ipairs(Workspace:GetChildren()) do
                if obj:IsA("Model") and obj.Name == "Bandit" then
                    EvaluateBandit(obj)
                    checked = true
                end
            end
            if cachedEntityFolder then
                for _, obj in ipairs(cachedEntityFolder:GetChildren()) do
                    if obj:IsA("Model") and obj.Name == "Bandit" then
                        EvaluateBandit(obj)
                        checked = true
                    end
                end
            end
            if not checked then
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj:IsA("Model") and obj.Name == "Bandit" then
                        EvaluateBandit(obj)
                        break
                    end
                end
            end
        end

        -- Barricade scan
        if KillAuraEnabled then
            if tick() - LastBarricadeScan > BarricadeScanInterval then
                table.clear(CachedBarricades)
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj:IsA("BasePart") and obj.Parent then
                        if isValidBarricade(obj) then
                            table.insert(CachedBarricades, obj)
                        end
                    end
                end
                LastBarricadeScan = tick()
            end
            
            for _, obj in ipairs(CachedBarricades) do
                if obj.Parent then
                    local dist = (obj.Position - hrp.Position).Magnitude
                    if dist < shortest and dist <= BarricadeRange then
                        shortest = dist
                        closest = obj
                        targetType = "Barricade"
                    end
                end
            end
        end
    end

    -- ===== AUTO FARM MOVEMENT =====
    if AutoFarmEnabled and closest and targetType == "NPC" and closest:FindFirstChild("Head") then
        local targetHead = closest.Head
        local targetPos = targetHead.Position - Vector3.new(0, UndergroundDepth, 0)
        local currentPos = hrp.Position
        local newPos = Vector3.new(
            currentPos.X + (targetPos.X - currentPos.X) * MoveSpeed,
            targetPos.Y,
            currentPos.Z + (targetPos.Z - currentPos.Z) * MoveSpeed
        )
        hrp.CFrame = CFrame.new(newPos)
        hrp.Velocity = Vector3.new(0, 0, 0)
    elseif AutoFarmEnabled then
        local safeY = -UndergroundDepth + 10
        hrp.CFrame = CFrame.new(hrp.Position.X, safeY, hrp.Position.Z)
        hrp.Velocity = Vector3.new(0, 0, 0)
    end

    -- ===== UNIFIED KILL AURA (NPCs + Barricades) =====
    KillAuraCD = KillAuraCD + delta
    if KillAuraEnabled and KillAuraCD > KILL_AURA_BASE_COOLDOWN and closest and tool then
        if targetType == "NPC" then
            KillAuraCD = 0
            local targetHead = closest:FindFirstChild("Head")
            if targetHead then
                local finalTargetPart = targetHead
                if closest.Name == "ZomborgPrime" or closest.Name:lower():find("zomborg") then
                    local powerSource = closest:FindFirstChild("PowerSource")
                    if powerSource then
                        if powerSource.Color.R < 0.3 and powerSource.Color.G < 0.3 and powerSource.Color.B < 0.3 then
                            finalTargetPart = targetHead
                        else
                            finalTargetPart = powerSource
                        end
                    end
                end
                local targetHum = isBanditTarget and (closest:FindFirstChild("Humanoid") or closest:FindFirstChildWhichIsA("Humanoid")) 
                                   or closest:FindFirstChild("Zombie") 
                                   or closest:FindFirstChild("Humanoid") 
                                   or closest:FindFirstChildWhichIsA("Humanoid")
                if targetHum and (finalTargetPart.Position - hrp.Position).Magnitude <= KillRange then
                    local storageId = tool:GetAttribute("StorageItemId") or tool.Name
                    local bulletOrigin = GetBulletOrigin(tool) or hrp
                    ReplicatedStorage.Library.RemotesManager.PrimaryFire:FireServer(
                        storageId, tool,
                        {
                            ["ShotPoint"] = hrp.CFrame.Position,
                            ["Direction"] = (finalTargetPart.Position - hrp.CFrame.Position).Unit,
                            ["AmmoData"] = {["MaxAmmo"] = 999, ["Ammo"] = 999},
                            ["TracerColor"] = Color3.new(1,1,1),
                            ["ShotId"] = 1,
                            ["HitInfoList"] = {{["Normal"] = Vector3.new(0,1,0), ["Part"] = finalTargetPart, ["Position"] = finalTargetPart.Position}},
                            ["ShotOrigin"] = bulletOrigin,
                            ["Victims"] = {{["Humanoid"] = targetHum, ["Object"] = finalTargetPart}},
                            ["TargetPoints"] = {finalTargetPart.Position}
                        }
                    )
                end
            end
        elseif targetType == "Barricade" then
            if tick() - LastBarricadeHit > BarricadeHitCD then
                LastBarricadeHit = tick()
                local storageId = tool:GetAttribute("StorageItemId") or tool.Name
                local bulletOrigin = GetBulletOrigin(tool) or hrp
                ReplicatedStorage.Library.RemotesManager.PrimaryFire:FireServer(
                    storageId, tool,
                    {
                        ["ShotPoint"] = hrp.CFrame.Position,
                        ["Direction"] = (closest.Position - hrp.CFrame.Position).Unit,
                        ["AmmoData"] = {["MaxAmmo"] = 999, ["Ammo"] = 999},
                        ["TracerColor"] = Color3.new(1,1,1),
                        ["ShotId"] = 1,
                        ["HitInfoList"] = {{["Normal"] = Vector3.new(0,1,0), ["Part"] = closest, ["Position"] = closest.Position}},
                        ["ShotOrigin"] = bulletOrigin,
                        ["Victims"] = {{["Humanoid"] = nil, ["Object"] = closest}},
                        ["TargetPoints"] = {closest.Position}
                    }
                )
            end
        end
    end

    -- ===== HELICOPTER KILL AURA =====
    if HeliKillAuraEnabled and tool and tick() - HeliLastShot > 0.18 then
        local entityFolder = cachedEntityFolder or Workspace:FindFirstChild("Entity")
        cachedEntityFolder = entityFolder
        if entityFolder then
            local bestPart = nil
            local bestDist = math.huge
            for _, pilot in ipairs(entityFolder:GetChildren()) do
                if pilot.Name == "Bandit Pilot" then
                    for _, part in ipairs(pilot:GetDescendants()) do
                        if part:IsA("BasePart") then
                            local dist = (part.Position - hrp.Position).Magnitude
                            if dist < 300 and dist < bestDist then
                                bestDist = dist
                                bestPart = part
                            end
                        end
                    end
                end
            end
            if bestPart then
                local storageId = tool:GetAttribute("StorageItemId") or tool.Name
                local bulletOrigin = GetBulletOrigin(tool) or hrp
                ReplicatedStorage.Library.RemotesManager.PrimaryFire:FireServer(
                    storageId, tool,
                    {
                        ["ShotPoint"] = hrp.CFrame.Position,
                        ["Direction"] = (bestPart.Position - hrp.CFrame.Position).Unit,
                        ["AmmoData"] = {["MaxAmmo"] = 999, ["Ammo"] = 999},
                        ["TracerColor"] = Color3.new(1,1,1),
                        ["ShotId"] = 1,
                        ["HitInfoList"] = {{["Normal"] = Vector3.new(0,1,0), ["Part"] = bestPart, ["Position"] = bestPart.Position}},
                        ["ShotOrigin"] = bulletOrigin,
                        ["Victims"] = {{["Humanoid"] = nil, ["Object"] = bestPart}},
                        ["TargetPoints"] = {bestPart.Position}
                    }
                )
                HeliLastShot = tick()
            end
        end
    end
end)

