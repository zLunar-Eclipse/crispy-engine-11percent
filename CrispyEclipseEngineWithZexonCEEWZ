end

local function buildGiftFilterState()
    return {
        rarity = getGiftFilterSelectionSet("GiftFilterRaritySelections", _G.GiftFilterRarity, normalizeRarityToken),
        mold = getGiftFilterSelectionSet("GiftFilterMoldSelections", _G.GiftFilterMold, normalizeMoldToken),
        enchant = getGiftFilterSelectionSet("GiftFilterEnchantSelections", _G.GiftFilterEnchant, normalizeEnchantToken),
        cracked = getGiftFilterSelectionSet("GiftFilterCrackedSelections", _G.GiftFilterCracked, normalizeToken)
    }
end

local function enchantSelectionMatchesEntry(selectionSet, entry)
    if selectionSet.any then
        return true
    end

    local entryEnchantMap = type(entry.enchantNormalized) == "table" and entry.enchantNormalized or nil
    if not entryEnchantMap then
        return false
    end

    for selectedToken in pairs(selectionSet) do
        for entryToken in pairs(entryEnchantMap) do
            if entryToken == selectedToken then
                return true
            end
            if #selectedToken >= 7 then
                if string.find(entryToken, selectedToken, 1, true) or string.find(selectedToken, entryToken, 1, true) then
                    return true
                end
            end
        end
    end

    return false
end

local function crackedSelectionMatchesEntry(selectionSet, entry)
    if selectionSet.any then
        return true
    end

    local wantsCrackedOnly = selectionSet["cracked only"] == true
    local wantsNotCracked = selectionSet["not cracked"] == true
    if wantsCrackedOnly and wantsNotCracked then
        return true
    end
    if wantsCrackedOnly then
        return entry.cracked == true
    end
    if wantsNotCracked then
        return entry.cracked ~= true
    end

    return true
end

local function filterSwordGiftEntry(entry, filterState)
    local state = filterState or buildGiftFilterState()

    if not state.rarity.any then
        if not state.rarity[normalizeRarityToken(entry.rarityName)] then
            return false
        end
    end

    if not state.mold.any then
        if not state.mold[normalizeMoldToken(entry.moldName)] then
            return false
        end
    end

    if not enchantSelectionMatchesEntry(state.enchant, entry) then
        return false
    end

    if not crackedSelectionMatchesEntry(state.cracked, entry) then
        return false
    end

    return true
end

local function dropMatchingGiftSwordsOnce()
    local entries = getCurrentGiftSwordEntries()
    local matchedIds = {}
    local filterState = buildGiftFilterState()
    for _, entry in ipairs(entries) do
        if filterSwordGiftEntry(entry, filterState) then
            table.insert(matchedIds, entry.id)
        end
    end

    local firedCount = 0
    for _, giftId in ipairs(matchedIds) do
        if fireFrameworkService("ProductHandler", "AcceptGift", { tostring(giftId) }) then
            firedCount = firedCount + 1
        end
        task.wait(0.08)
    end

    return firedCount, #matchedIds, #entries
end

local function isToolCracked(tool)
