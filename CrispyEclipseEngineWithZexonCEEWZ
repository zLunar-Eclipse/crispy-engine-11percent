    local function normalizeSelectionList(raw, optionOrder)
        local list = {}
        if type(raw) ~= "table" then
            local single = optionToString(raw)
            if single ~= "" then
                table.insert(list, single)
            end
            return list
        end

        local hasBooleanMap = false
        for _, state in pairs(raw) do
            if type(state) == "boolean" then
                hasBooleanMap = true
                break
            end
        end

        if hasBooleanMap then
            if type(optionOrder) == "table" then
                for _, option in ipairs(optionOrder) do
                    local name = optionToString(option)
                    if raw[name] == true then
                        table.insert(list, name)
                    end
                end
            end

            for key, state in pairs(raw) do
                if state == true then
                    local name = optionToString(key)
                    if name ~= "" then
                        local exists = false
                        for _, existing in ipairs(list) do
                            if existing == name then
                                exists = true
                                break
                            end
                        end
                        if not exists then
                            table.insert(list, name)
                        end
                    end
                end
            end
            return list
        end

        for _, value in pairs(raw) do
            local name = optionToString(value)
            if name ~= "" then
                table.insert(list, name)
            end
        end
        return list
    end

    local function normalizeSingleSelection(raw)
        if type(raw) == "table" then
            local list = normalizeSelectionList(raw)
            return list[1]
        end
        local text = optionToString(raw)
        if text == "" then
            return nil
        end
        return text
    end

    local function convertMultiSelectionToMap(list)
        local mapped = {}
        if type(list) ~= "table" then
            local name = optionToString(list)
            if name ~= "" then
                mapped[name] = true
            end
            return mapped
        end
        for _, value in ipairs(list) do
            local name = optionToString(value)
            if name ~= "" then
                mapped[name] = true
            end
        end
        return mapped
    end

    local fluentControlId = 0
