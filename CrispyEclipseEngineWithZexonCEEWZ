function getLocalPlayerBase()
    local function normalizeBaseToken(value)
        local token = string.lower(tostring(value or ""))
        token = token:gsub("%s+", "")
        token = token:gsub("[^%w]", "")
        return token
    end

    local cachedBase = _G.__ZexonLocalBaseCache
    if cachedBase and cachedBase.Parent then
        return cachedBase
    end

    local expectedName = localPlayer.Name .. "'s Base"
    local expectedDirect = workspace:FindFirstChild(expectedName)
    if expectedDirect and expectedDirect:IsA("Model") then
        _G.__ZexonLocalBaseCache = expectedDirect
        return expectedDirect
    end

    local localNameToken = normalizeBaseToken(localPlayer.Name)
    local displayNameToken = normalizeBaseToken(localPlayer.DisplayName)
    local localUserId = tonumber(localPlayer.UserId)

    local bestBase = nil
    local bestScore = -math.huge
    local visited = {}

    local function scoreBaseCandidate(model)
        if not (model and model:IsA("Model")) then
            return
        end
        if visited[model] then
            return
        end
        visited[model] = true

        local score = 0
        local loweredName = string.lower(model.Name)
        if string.find(loweredName, "base", 1, true) then
            score = score + 4
        end
        if model.Name == expectedName then
            score = score + 40
        end

        local normalizedModelName = normalizeBaseToken(model.Name)
        if localNameToken ~= "" and string.find(normalizedModelName, localNameToken, 1, true) then
            score = score + 14
        end
        if displayNameToken ~= "" and string.find(normalizedModelName, displayNameToken, 1, true) then
            score = score + 10
        end

        local ownerValue = model:FindFirstChild("Owner")
        if ownerValue then
            if ownerValue:IsA("ObjectValue") and ownerValue.Value == localPlayer then
                score = score + 120
            end

            local ownerText = ""
            local okOwnerText = pcall(function()
                ownerText = tostring(ownerValue.Value or "")
            end)
            if okOwnerText and ownerText ~= "" then
                local normalizedOwner = normalizeBaseToken(ownerText)
                if normalizedOwner == localNameToken or (displayNameToken ~= "" and normalizedOwner == displayNameToken) then
                    score = score + 95
                end
            end
        end

        local idHolder = model:FindFirstChild("OwnerUserId")
            or model:FindFirstChild("UserId")
            or model:FindFirstChild("PlayerUserId")
        if idHolder then
            local ownerId = tonumber(idHolder.Value)
            if ownerId and localUserId and ownerId == localUserId then
                score = score + 110
            end
        end

        local attrOwnerId = tonumber(
            model:GetAttribute("OwnerUserId")
            or model:GetAttribute("UserId")
            or model:GetAttribute("PlayerUserId")
        )
        if attrOwnerId and localUserId and attrOwnerId == localUserId then
            score = score + 110
        end

        if model:FindFirstChild("Ascender") or model:FindFirstChild("Ascenders") then
            score = score + 8
        end

        if score > bestScore then
            bestScore = score
            bestBase = model
        end
    end

    for _, child in ipairs(workspace:GetChildren()) do
        scoreBaseCandidate(child)
    end

    local likelyFolders = {
        workspace:FindFirstChild("Bases"),
        workspace:FindFirstChild("Base"),
        workspace:FindFirstChild("Plots"),
        workspace:FindFirstChild("Islands"),
        workspace:FindFirstChild("Map")
    }
    for _, folder in ipairs(likelyFolders) do
        if folder then
            for _, child in ipairs(folder:GetChildren()) do
                scoreBaseCandidate(child)
            end
        end
    end

    if not bestBase then
        local now = os.clock()
        local allowDeepScan = (tonumber(_G.__ZexonLastBaseDeepScanAt) or 0) + 5 <= now
        if allowDeepScan then
            _G.__ZexonLastBaseDeepScanAt = now
            for _, descendant in ipairs(workspace:GetDescendants()) do
                if descendant:IsA("Model") then
                    scoreBaseCandidate(descendant)
                end
            end
        end
    end

    if bestBase then
        _G.__ZexonLocalBaseCache = bestBase
        return bestBase
    end

    local fallback = workspace:FindFirstChild(expectedName) or workspace:WaitForChild(expectedName, 2)
    if fallback and fallback:IsA("Model") then
        _G.__ZexonLocalBaseCache = fallback
    end
    return fallback
end

function getAscenderUpgradeTarget()
    local _, ascenderIndex = normalizeAscenderSelection(_G.SelectedAscender)
    local base = getLocalPlayerBase()
    if not base then
        return nil
    end
    local ascenderFolder = base:FindFirstChild("Ascender") or base:FindFirstChild("Ascenders")
    if not ascenderFolder then
        _G.__ZexonLocalBaseCache = nil
        return nil
    end

    local targetName = "Ascender" .. tostring(ascenderIndex) .. "Luck"
    local target = ascenderFolder:FindFirstChild(targetName) or ascenderFolder:FindFirstChild(targetName, true)
    if target then
        return target
    end

    local targetLower = string.lower(targetName)
    local indexToken = "ascender" .. tostring(ascenderIndex)
    local bestMatch = nil
    local bestScore = -1
    for _, descendant in ipairs(ascenderFolder:GetDescendants()) do
        local score = 0
        local lowered = string.lower(descendant.Name)
        if lowered == targetLower then
            return descendant
        end
        if string.find(lowered, indexToken, 1, true) then
            score = score + 5
        end
        if string.find(lowered, "luck", 1, true) then
            score = score + 4
        end
        if descendant:IsA("BasePart") then
            score = score + 2
        end
        if score > bestScore then
            bestScore = score
            bestMatch = descendant
        end
    end

    if bestMatch and bestScore >= 7 then
        return bestMatch
    end

    _G.__ZexonLocalBaseCache = nil
    return nil
end

