                    .. " | Gain: " .. formatMetricNumber(metric.delta)
                    .. " | Now: " .. getMetricCurrentText(metric)
                )
            end
        end
        if #lines == 0 then
            return "Waiting for gem/cash/xp stats..."
        end
        return table.concat(lines, "\n")
    end

