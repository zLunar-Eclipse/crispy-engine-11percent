local function findNearestCrackedFloorSword()
    local itemsFolder = workspace:FindFirstChild("Items")
    if not itemsFolder then
        return nil, nil
    end

    local inventoryIds, bankedIds = refreshOwnedItemCaches()
    local hrp = getHumanoidRootPart()
    local bestPart = nil
    local bestItemId = nil
    local bestDistance = math.huge

    for _, itemModel in ipairs(itemsFolder:GetChildren()) do
        if itemModel:IsA("Model") then
            local config = itemModel:FindFirstChild("Config")
            local crackedValue = config and config:FindFirstChild("Cracked")
            local itemIdValue = config and config:FindFirstChild("ITEMID")
            local currentOwnerValue = config and config:FindFirstChild("CurrentOwner")
            local ownerValue = config and config:FindFirstChild("Owner")

            local isCracked = crackedValue and crackedValue:IsA("BoolValue") and crackedValue.Value == true
            local itemId = itemIdValue and tonumber(itemIdValue.Value)
            local ownerName = ""
            if currentOwnerValue and currentOwnerValue:IsA("StringValue") then
                ownerName = currentOwnerValue.Value
            elseif ownerValue and ownerValue:IsA("StringValue") then
                ownerName = ownerValue.Value
            end

            if isCracked and itemId then
                local ownerMatches = ownerName == "" or ownerName == localPlayer.Name
                if ownerMatches and not inventoryIds[itemId] and not bankedIds[itemId] then
                    local itemPart = getItemModelPart(itemModel)
                    if itemPart then
                        local distance = hrp and (hrp.Position - itemPart.Position).Magnitude or 0
                        if distance < bestDistance then
                            bestDistance = distance
                            bestPart = itemPart
                            bestItemId = itemId
                        end
                    end
                end
            end
        end
    end

    return bestPart, bestItemId
end

