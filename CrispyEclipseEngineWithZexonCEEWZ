local collectorState = {
    lastTargetId = nil,
    lastAttemptAt = 0
}

local function tryCollectCrackedSword()
    local targetPart, targetItemId = findNearestCrackedFloorSword()
    if not targetPart or not targetItemId then
        return
    end

    local now = os.clock()
    if collectorState.lastTargetId == targetItemId and now - collectorState.lastAttemptAt < 0.9 then
        return
    end

    local dropTool = findDroppableTool()
    if not dropTool then
        return
    end

    local character = getCharacter()
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if humanoid and dropTool.Parent ~= character then
        humanoid:EquipTool(dropTool)
        task.wait(0.12)
    end

    if isToolCracked(dropTool) then
        return
    end

    if requestDropCurrentTool() then
        collectorState.lastTargetId = targetItemId
        collectorState.lastAttemptAt = now
        for _ = 1, 2 do
            if not _G.AutoCollectCrackedSwords then
                break
            end
            teleportToPosition(targetPart.Position)
            task.wait(0.16)
        end
    end
end

