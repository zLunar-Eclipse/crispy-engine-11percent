local chestOpenStateNames = {
    opened = true,
    open = true,
    isopen = true,
    claimed = true,
    collected = true,
    looted = true,
    taken = true
}
local function hasChestOpenStateFlag(chest)
    if not chest then
        return false
    end
    local attributes = chest:GetAttributes()
    for attrName, attrValue in pairs(attributes) do
        if type(attrValue) == "boolean" and attrValue == true then
            if chestOpenStateNames[string.lower(tostring(attrName))] then
                return true
            end
        end
    end
    for _, descendant in ipairs(chest:GetDescendants()) do
        local lowerName = string.lower(descendant.Name)
        if chestOpenStateNames[lowerName] then
            if descendant:IsA("BoolValue") then
                if descendant.Value == true then
                    return true
                end
            else
                return true
            end
        end
    end
    return false
end
local function isChestOpened(chest)
    if not chest or not chest.Parent then
        return true
    end
    if shouldIgnoreChest(chest) then
        return true
    end
    if hasChestOpenStateFlag(chest) then
        return true
    end
    local hasEnabledPrompt, hasAnyPrompt = hasEnabledChestPrompt(chest)
    if hasAnyPrompt and not hasEnabledPrompt then
        if dungeonState.chestPromptWasEnabled[chest] == true then
            return true
        end
        local key = getChestKey(chest)
        if key and dungeonState.chestOpenedKeys[key] == true then
            return true
        end
        local attempts = tonumber(dungeonState.chestAttempts[chest]) or 0
        if key then
            attempts = math.max(attempts, tonumber(dungeonState.chestAttempts[key]) or 0)
        end
        if attempts >= 2 then
            return true
        end
        return false
    end
    ensureChestBaseline(chest)
    local baseline = dungeonState.chestBaselines[chest]
    local currentPivot = getChestLidPivot(chest)
    if baseline and currentPivot then
        local dot = math.clamp(baseline.LookVector:Dot(currentPivot.LookVector), -1, 1)
        local angle = math.deg(math.acos(dot))
        if angle >= 14 then
            return true
        end
    end

    return false
end

local function getChestInteractPart(chest)
    if not chest then
        return nil
    end

    local chestBase = chest:FindFirstChild("Chest_Base")
    local baseBody = chestBase and chestBase:FindFirstChild("Body")
    if baseBody and baseBody:IsA("BasePart") then
        return baseBody
    end

    local chestLid = chest:FindFirstChild("Chest_Lid")
    local lidBody = chestLid and chestLid:FindFirstChild("Body")
    if lidBody and lidBody:IsA("BasePart") then
        return lidBody
    end

    if chest.PrimaryPart then
        return chest.PrimaryPart
    end

    return chest:FindFirstChildWhichIsA("BasePart", true)
end

local function getChestTargetPosition(chest)
    if not chest then
        return nil
    end

    local interactPart = getChestInteractPart(chest)
    if interactPart then
        return interactPart.Position
    end

    local ok, pivot = pcall(function()
        return chest:GetPivot()
    end)
    if ok and pivot then
        return pivot.Position
    end

    return nil
end

local function getChestKey(chest)
    if not chest or not chest.Parent then
        return nil
    end

    local fullName = chest:GetFullName()
    local chestBase = chest:FindFirstChild("Chest_Base")
    local baseBody = chestBase and chestBase:FindFirstChild("Body")
    if baseBody and baseBody:IsA("BasePart") then
        local pos = baseBody.Position
        return string.format(
            "%s|%d|%d|%d",
            fullName,
            math.floor(pos.X * 2 + 0.5),
            math.floor(pos.Y * 2 + 0.5),
            math.floor(pos.Z * 2 + 0.5)
        )
    end

    return fullName
end

local function markChestOpened(chest)
    if not chest then
        return
    end

    dungeonState.chestOpenedInstances[chest] = true
    local key = getChestKey(chest)
    if key then
        dungeonState.chestOpenedKeys[key] = true
        dungeonState.chestAttempts[key] = -1
    end
    dungeonState.chestAttempts[chest] = -1
end

local function isChestKnownOpened(chest)
    if not chest then
        return true
    end

    if dungeonState.chestOpenedInstances[chest] == true then
        return true
    end

    local key = getChestKey(chest)
    if key and dungeonState.chestOpenedKeys[key] == true then
        dungeonState.chestOpenedInstances[chest] = true
        return true
    end

    if isChestOpened(chest) then
        dungeonState.chestOpenedInstances[chest] = true
        if key then
            dungeonState.chestOpenedKeys[key] = true
        end
        return true
    end

    return false
end

local function triggerPrompt(prompt)
    if typeof(fireproximityprompt) == "function" then
        local ok = pcall(function()
            fireproximityprompt(prompt, 1)
        end)
        if ok then
            return true
        end
    end

    return pcall(function()
        local oldHoldDuration = prompt.HoldDuration
        prompt.HoldDuration = 0
        prompt:InputHoldBegin()
        task.wait(0.08)
        prompt:InputHoldEnd()
        prompt.HoldDuration = oldHoldDuration
    end)
end

local CHEST_PROMPT_RETRIES = 2
local CHEST_RESNAP_INTERVAL = 0.08
local CHEST_SPAM_TICK = 0.01

local function openChestModel(chest)
    if shouldIgnoreChest(chest) then
        markChestOpened(chest)
        return true, false
    end

    local attempted = false
    local snapOffsets = {
        Vector3.new(0, 0, 0),
        Vector3.new(2, 0, 0),
        Vector3.new(-2, 0, 0),
        Vector3.new(0, 0, 2),
        Vector3.new(0, 0, -2)
    }
    local snapIndex = 1

    local function snapToChest()
        local targetPos = getChestTargetPosition(chest)
        if not targetPos then
            return false
        end

        local offset = snapOffsets[snapIndex]
        snapIndex = (snapIndex % #snapOffsets) + 1
        teleportToPosition(targetPos + offset)
        return true
    end

    local spamDuration = getChestOpenSpamTime()
    local finishAt = os.clock() + spamDuration
    local nextSnapAt = 0

    while shouldRunFarmLoop() and inDungeon() and isRuntimeActive() and os.clock() < finishAt do
        local now = os.clock()
        if now >= nextSnapAt then
            snapToChest()
            nextSnapAt = now + CHEST_RESNAP_INTERVAL
        end

        local prompts = getChestPrompts(chest)
        for _, prompt in ipairs(prompts) do
            if prompt and prompt.Parent and prompt.Enabled then
                if triggerPrompt(prompt) then
                    attempted = true
                end
                dungeonState.chestPromptWasEnabled[chest] = true
            end
        end

        if doAttack("Dungeon") then
            attempted = true
        end
        task.wait(CHEST_SPAM_TICK)
    end

    for _ = 1, CHEST_PROMPT_RETRIES do
        local prompts = getChestPrompts(chest)
        for _, prompt in ipairs(prompts) do
            if prompt and prompt.Parent and prompt.Enabled then
                if triggerPrompt(prompt) then
                    attempted = true
                end
                dungeonState.chestPromptWasEnabled[chest] = true
            end
        end
        task.wait(0.02)
    end

    markChestOpened(chest)
    return true, attempted
end

local function openDungeonChests()
    local chests = collectDungeonChests()
    local targetChests = {}

    for _, chest in ipairs(chests) do
        if not shouldIgnoreChest(chest) then
            ensureChestBaseline(chest)
            table.insert(targetChests, chest)
        end
    end

    if not dungeonState.lootChestScanLogged then
        print("[Zexon Hub] Chest candidates:", #targetChests)
        dungeonState.lootChestScanLogged = true
    end

    if #targetChests == 0 then
        if not dungeonState.lootNoChestWarned then
            warn("[Zexon Hub] No dungeon chests found.")
            dungeonState.lootNoChestWarned = true
        end
        return false
    end
    dungeonState.lootNoChestWarned = false

    local hrp = getHumanoidRootPart()
    if hrp then
        local origin = hrp.Position
        table.sort(targetChests, function(a, b)
            local aPos = getChestTargetPosition(a)
            local bPos = getChestTargetPosition(b)
            local aDistance = aPos and (aPos - origin).Magnitude or math.huge
            local bDistance = bPos and (bPos - origin).Magnitude or math.huge
            return aDistance < bDistance
        end)
    end

    for _, chest in ipairs(targetChests) do
        if not shouldRunFarmLoop() or not inDungeon() or not isRuntimeActive() then
            return false
        end

        openChestModel(chest)
        task.wait(getChestTeleportDelay())
    end

    return true
end

local function teleportBackToGraveyard()
    local firedAny = false

    local framework = ReplicatedStorage:FindFirstChild("Framework")
    local frameworkRemote = framework and framework:FindFirstChild("RemoteEvent")
    if frameworkRemote and frameworkRemote:IsA("RemoteEvent") then
        local args = {
            0,
            "UIServer",
            "Teleport",
            {}
        }
        pcall(function()
            frameworkRemote:FireServer(unpack(args))
        end)
        firedAny = true
    end

    task.wait(0.12)

    local events = ReplicatedStorage:FindFirstChild("Events")
    local toMapRemote = events and events:FindFirstChild("ToMap")
    local data = ReplicatedStorage:FindFirstChild("Data") or ReplicatedStorage:WaitForChild("Data", 2)
    local playerData = data and (data:FindFirstChild(localPlayer.Name) or data:WaitForChild(localPlayer.Name, 2))
    local stats = playerData and (playerData:FindFirstChild("Stats") or playerData:WaitForChild("Stats", 2))
    local playerBaseName = localPlayer.Name .. "'s Base"
    local playerBase = workspace:FindFirstChild(playerBaseName) or workspace:WaitForChild(playerBaseName, 2)
    if toMapRemote and toMapRemote:IsA("RemoteEvent") and stats and playerBase then
        local args = {
            stats,
            playerBase,
            localPlayer.Name,
            "Graveyard"
        }
        pcall(function()
            toMapRemote:FireServer(unpack(args))
        end)
        firedAny = true
    end

    if firedAny then
        dungeonState.returnTriggered = true
        dungeonState.nextReturnRetryAt = os.clock() + 1.5
        dungeonState.forceLobbyUntil = os.clock() + 120
    else
        dungeonState.nextReturnRetryAt = os.clock() + 0.75
    end
end

function normalizeWorldFarmToken(value)
    local token = string.lower(tostring(value or ""))
    token = token:gsub("_", " ")
    token = token:gsub("%s+", " ")
    token = token:gsub("^%s+", "")
    token = token:gsub("%s+$", "")
    return token
end

function getWorldFarmMode()
    local mode = tostring(_G.WorldFarmMode or "Normal")
    if mode ~= "Normal" and mode ~= "With Dungeon" then
        mode = "Normal"
    end
    _G.WorldFarmMode = mode
    return mode
end

function isWorldFarmEnabled()
    return _G.WorldFarmEnabled == true
end

function shouldRunFarmLoop()
    return (_G.AutoFarm == true) or isWorldFarmEnabled()
end

function isGenericWorldFarmMobName(name)
    local token = normalizeWorldFarmToken(name)
    if token == "" or token == "any" then
        return true
    end
    if string.match(token, "^%d+$") then
        return true
    end

    local blockedNames = {
        ["model"] = true,
        ["part"] = true,
        ["folder"] = true,
        ["map"] = true,
        ["maps"] = true,
        ["mobspawns"] = true,
        ["mob spawn"] = true,
        ["spawns"] = true,
        ["spawn"] = true,
        ["chests"] = true,
        ["gates"] = true,
        ["info"] = true,
        ["rewards"] = true
    }
    return blockedNames[token] == true
end

function addWorldFarmMobOption(outSet, rawName)
    local name = tostring(rawName or ""):gsub("^%s+", ""):gsub("%s+$", "")
    if isGenericWorldFarmMobName(name) then
        return
    end
    local token = normalizeWorldFarmToken(name)
    if token == "" then
        return
    end
    if outSet[token] == nil then
        outSet[token] = name
    end
end

function normalizeWorldFarmMobSelection(source, options)
    local selectionSet = {}
    local selectionList = {}
    local seenTokens = {}
    local optionByToken = {}

    if type(options) == "table" then
        for _, option in ipairs(options) do
            optionByToken[normalizeWorldFarmToken(option)] = tostring(option)
        end
    end

    local anySelected = false
    local function register(rawValue)
        local token = normalizeWorldFarmToken(rawValue)
        if token == "" then
            return
        end
        if token == "any" then
            anySelected = true
            return
        end
        if seenTokens[token] then
            return
        end
        seenTokens[token] = true
        selectionSet[token] = true
        table.insert(selectionList, optionByToken[token] or tostring(rawValue))
    end

    if type(source) == "table" then
        for key, value in pairs(source) do
            if type(key) == "string" and value == true then
                register(key)
            elseif type(value) == "string" or type(value) == "number" then
                register(value)
            elseif type(key) == "number" and value == true then
                register(key)
            end
            if anySelected then
                break
            end
        end
    elseif source ~= nil then
        register(source)
    end

    if anySelected or next(selectionSet) == nil then
        return { any = true }, { "Any" }
    end

    if type(options) == "table" and #options > 0 then
        local ordered = {}
        local appended = {}
        for _, option in ipairs(options) do
            local token = normalizeWorldFarmToken(option)
            if selectionSet[token] and not appended[token] then
                table.insert(ordered, option)
                appended[token] = true
            end
        end
        for _, fallback in ipairs(selectionList) do
            local token = normalizeWorldFarmToken(fallback)
            if selectionSet[token] and not appended[token] then
                table.insert(ordered, fallback)
                appended[token] = true
            end
        end
        selectionList = ordered
    end

    return selectionSet, selectionList
end

function getWorldFarmMobSelectionSet(options)
    local selectionSet, selectionList = normalizeWorldFarmMobSelection(_G.WorldFarmMobSelections, options)
    _G.WorldFarmMobSelections = selectionList
    return selectionSet, selectionList
end

function mobMatchesWorldFarmSelection(mobName, selectionSet)
    if selectionSet.any then
        return true
    end

    local mobToken = normalizeWorldFarmToken(mobName)
    if selectionSet[mobToken] then
        return true
    end

    for selectedToken in pairs(selectionSet) do
        if selectedToken ~= "any" then
            if string.find(mobToken, selectedToken, 1, true) or string.find(selectedToken, mobToken, 1, true) then
                return true
            end
        end
    end

    return false
end

function getTeleportInfoModule()
    if cachedTeleportInfoModule == false then
        return nil
    end
    if cachedTeleportInfoModule ~= nil then
        return cachedTeleportInfoModule
    end

    local sharedModules = ReplicatedStorage:FindFirstChild("SharedModules")
    local teleportInfoModule = sharedModules and sharedModules:FindFirstChild("TeleportInfo")
    if teleportInfoModule and teleportInfoModule:IsA("ModuleScript") then
        local ok, result = pcall(require, teleportInfoModule)
        if ok and type(result) == "table" then
            cachedTeleportInfoModule = result
            return result
        end
    end

    cachedTeleportInfoModule = false
    return nil
end

function getWorldFarmIslandOptions()
    local options = {}
    local seen = {}
    local levelRequirements = {}

    local teleportInfo = getTeleportInfoModule()
    local areaInfo = teleportInfo and teleportInfo.AreaInfo
    if type(areaInfo) == "table" then
        for islandName, levelRequirement in pairs(areaInfo) do
            if type(islandName) == "string" and islandName ~= "" and not seen[islandName] then
                seen[islandName] = true
                table.insert(options, islandName)
                levelRequirements[islandName] = tonumber(levelRequirement)
            end
        end
    end

    local maps = workspace:FindFirstChild("Maps")
    if maps then
        for _, islandModel in ipairs(maps:GetChildren()) do
            if islandModel:IsA("Model") and not seen[islandModel.Name] then
                seen[islandModel.Name] = true
                table.insert(options, islandModel.Name)
            end
        end
    end

    if #options == 0 then
        options = { "Noob Island", "Graveyard" }
    end

    table.sort(options, function(a, b)
        local reqA = levelRequirements[a]
        local reqB = levelRequirements[b]
        if reqA ~= nil or reqB ~= nil then
            if reqA == nil then
                return false
            end
            if reqB == nil then
                return true
            end
            if reqA ~= reqB then
                return reqA < reqB
            end
        end
        return string.lower(a) < string.lower(b)
    end)

    return options
end

function collectWorldFarmMobNamesFromContainer(container, outSet)
    if not container then
        return
    end

    for _, descendant in ipairs(container:GetDescendants()) do
        if descendant:IsA("Model") then
            addWorldFarmMobOption(outSet, descendant.Name)
        elseif descendant:IsA("StringValue") then
            local keyToken = normalizeWorldFarmToken(descendant.Name)
            if string.find(keyToken, "mob", 1, true)
                or string.find(keyToken, "enemy", 1, true)
                or keyToken == "name" then
                addWorldFarmMobOption(outSet, descendant.Value)
            end
        elseif descendant:IsA("ObjectValue") then
            local keyToken = normalizeWorldFarmToken(descendant.Name)
            if descendant.Value and descendant.Value:IsA("Model")
                and (string.find(keyToken, "mob", 1, true)
                    or string.find(keyToken, "enemy", 1, true)
                    or keyToken == "template"
                    or keyToken == "model") then
                addWorldFarmMobOption(outSet, descendant.Value.Name)
            end
        end

        local okAttributes, attributes = pcall(function()
            return descendant:GetAttributes()
        end)
        if okAttributes and type(attributes) == "table" then
            for attrName, attrValue in pairs(attributes) do
                if type(attrValue) == "string" then
                    local attrToken = normalizeWorldFarmToken(attrName)
                    if string.find(attrToken, "mob", 1, true)
                        or string.find(attrToken, "enemy", 1, true)
                        or attrToken == "mobname" then
                        addWorldFarmMobOption(outSet, attrValue)
                    end
                end
            end
        end
    end
end

function getWorldFarmMobOptions(islandOptions)
    local optionSet = {}
    addWorldFarmMobOption(optionSet, "Any")

    local liveMobs = getMobsFolder()
    if liveMobs then
        for _, mob in ipairs(liveMobs:GetChildren()) do
            if mob:IsA("Model") then
                addWorldFarmMobOption(optionSet, mob.Name)
            end
        end
    end

    local replicatedMobs = ReplicatedStorage:FindFirstChild("Mobs")
    if replicatedMobs then
        for _, mobTemplate in ipairs(replicatedMobs:GetChildren()) do
            if mobTemplate:IsA("Model") then
                addWorldFarmMobOption(optionSet, mobTemplate.Name)
            end
        end
    end

    local sharedModules = ReplicatedStorage:FindFirstChild("SharedModules")
    local mobModules = sharedModules and sharedModules:FindFirstChild("MobModules")
    local dropModifierModule = mobModules and mobModules:FindFirstChild("DropModifier")
    if dropModifierModule and dropModifierModule:IsA("ModuleScript") then
        local ok, dropModifier = pcall(require, dropModifierModule)
        local enemyTasks = ok and type(dropModifier) == "table" and dropModifier.enemyTasks or nil
        if type(enemyTasks) == "table" then
            for mobName in pairs(enemyTasks) do
                addWorldFarmMobOption(optionSet, mobName)
            end
        end
    end

    local maps = workspace:FindFirstChild("Maps")
    if maps then
        for _, islandName in ipairs(islandOptions or {}) do
            local islandModel = maps:FindFirstChild(islandName)
            if islandModel then
                collectWorldFarmMobNamesFromContainer(islandModel:FindFirstChild("MobSpawns"), optionSet)
                collectWorldFarmMobNamesFromContainer(islandModel:FindFirstChild("MapFunctionalSection"), optionSet)
            end
        end
    end

    local options = {}
    for _, name in pairs(optionSet) do
        table.insert(options, name)
    end
    table.sort(options, function(a, b)
        local aIsAny = normalizeWorldFarmToken(a) == "any"
        local bIsAny = normalizeWorldFarmToken(b) == "any"
        if aIsAny ~= bIsAny then
            return aIsAny
        end
        return string.lower(a) < string.lower(b)
    end)

    if #options == 0 then
        options = { "Any" }
    elseif normalizeWorldFarmToken(options[1]) ~= "any" then
        table.insert(options, 1, "Any")
    end

    return options
end

function buildWorldFarmCatalog(forceRefresh)
    local now = os.clock()
    local hasIslandCache = type(worldFarmCatalogCache.islands) == "table" and #worldFarmCatalogCache.islands > 0
    local hasMobCache = type(worldFarmCatalogCache.mobs) == "table" and #worldFarmCatalogCache.mobs > 0
    local cacheAge = now - (worldFarmCatalogCache.builtAt or 0)
    local cacheHasDetailedMobs = hasMobCache and #worldFarmCatalogCache.mobs > 1
    if forceRefresh ~= true and hasIslandCache and hasMobCache then
        if cacheHasDetailedMobs or cacheAge <= 20 then
            return worldFarmCatalogCache.islands, worldFarmCatalogCache.mobs
        end
    end

    local islands = getWorldFarmIslandOptions()
    local mobs = getWorldFarmMobOptions(islands)
    worldFarmCatalogCache.islands = islands
    worldFarmCatalogCache.mobs = mobs
    worldFarmCatalogCache.builtAt = now
    return islands, mobs
end

function getWorldFarmSelectedIsland(islandOptions)
    local selected = tostring(_G.WorldFarmIsland or "")
    if selected == "" then
        selected = "Noob Island"
    end

    if type(islandOptions) == "table" and #islandOptions > 0 then
        for _, option in ipairs(islandOptions) do
            if option == selected then
                _G.WorldFarmIsland = option
                return option
            end
        end

        local selectedToken = normalizeWorldFarmToken(selected)
        for _, option in ipairs(islandOptions) do
            if normalizeWorldFarmToken(option) == selectedToken then
                _G.WorldFarmIsland = option
                return option
            end
        end

        _G.WorldFarmIsland = islandOptions[1]
        return islandOptions[1]
    end

    _G.WorldFarmIsland = selected
    return selected
end

function isPlayerNearIsland(islandName)
    local hrp = getHumanoidRootPart()
    if not hrp then
        return false
    end

    local maps = workspace:FindFirstChild("Maps")
    local islandModel = maps and maps:FindFirstChild(islandName)
    if not islandModel then
        return false
    end

    local okPivot, pivot = pcall(function()
        return islandModel:GetPivot()
    end)
    if not okPivot or not pivot then
        return false
    end

    return (hrp.Position - pivot.Position).Magnitude <= 900
end

function teleportToIsland(islandName, force)
    local targetIsland = tostring(islandName or "")
    if targetIsland == "" then
        return false
    end

    local now = os.clock()
    if force ~= true then
        local sameIsland = worldFarmState.lastTeleportIsland == targetIsland
        local recentTeleport = now - (worldFarmState.lastTeleportAt or 0) < 3.5
        if sameIsland and recentTeleport then
            return false
        end
    end

    local events = ReplicatedStorage:FindFirstChild("Events")
    local toMapRemote = events and events:FindFirstChild("ToMap")
    local data = ReplicatedStorage:FindFirstChild("Data") or ReplicatedStorage:WaitForChild("Data", 2)
    local playerData = data and (data:FindFirstChild(localPlayer.Name) or data:WaitForChild(localPlayer.Name, 2))
    local stats = playerData and (playerData:FindFirstChild("Stats") or playerData:WaitForChild("Stats", 2))
    local playerBaseName = localPlayer.Name .. "'s Base"
    local playerBase = workspace:FindFirstChild(playerBaseName) or workspace:WaitForChild(playerBaseName, 2)
    local ownerValue = playerBase and playerBase:FindFirstChild("Owner")
    local ownerName = ownerValue and ownerValue.Value or localPlayer.Name

    if not (toMapRemote and toMapRemote:IsA("RemoteEvent") and stats and playerBase and ownerName) then
        return false
    end

    local fired = false
    pcall(function()
        toMapRemote:FireServer(stats, playerBase, ownerName, targetIsland)
        fired = true
    end)

    if fired then
        worldFarmState.lastTeleportAt = now
        worldFarmState.lastTeleportIsland = targetIsland
    end

    return fired
end

function shouldTeleportForWorldFarm(targetIsland, now)
    local currentTime = now or os.clock()
    local lastTeleportAt = worldFarmState.lastTeleportAt or 0
    local onTargetIsland = isPlayerNearIsland(targetIsland)
    if not onTargetIsland and currentTime - lastTeleportAt >= 1 then
        return true
    end

    if worldFarmState.lastTeleportIsland ~= targetIsland and currentTime - lastTeleportAt >= 1 then
        return true
    end

    if worldFarmState.noMobSince and currentTime - worldFarmState.noMobSince >= 2.5 and currentTime - lastTeleportAt >= 2 then
        return true
    end

    return false
end

function findWorldFarmTargetMob(selectionSet)
    return findNearestMob(function(mob)
        return mobMatchesWorldFarmSelection(mob.Name, selectionSet)
    end)
end

function fightWorldMob(mob, selectionSet)
    while shouldRunFarmLoop() and isRuntimeActive() and isWorldFarmEnabled() and not inDungeon() and isMobAlive(mob) do
        if selectionSet and not mobMatchesWorldFarmSelection(mob.Name, selectionSet) then
            return
        end

        local root = getMobRoot(mob)
        if root then
            teleportToPosition(root.Position)
        end
        doAttack("MobFarm")
        task.wait(0.045)
    end
end

function runWorldFarmPhase()
    local islandOptions, mobOptions = buildWorldFarmCatalog(false)
    local targetIsland = getWorldFarmSelectedIsland(islandOptions)
    local selectionSet = getWorldFarmMobSelectionSet(mobOptions)
    local now = os.clock()

    if shouldTeleportForWorldFarm(targetIsland, now) then
        teleportToIsland(targetIsland, false)
        task.wait(0.12)
    end

    local targetMob = findWorldFarmTargetMob(selectionSet)
    if targetMob then
        worldFarmState.noMobSince = nil
        fightWorldMob(targetMob, selectionSet)
        return
    end

    if not worldFarmState.noMobSince then
        worldFarmState.noMobSince = now
    end

    if now - worldFarmState.noMobSince >= 2.5 then
        teleportToIsland(targetIsland, true)
        worldFarmState.noMobSince = now
    end

    doAttack("MobFarm")
    task.wait(0.1)
end

