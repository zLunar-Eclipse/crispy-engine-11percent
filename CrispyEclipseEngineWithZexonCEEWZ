local function getOrderedTools()
    local tools = {}
    local hasExplicitSlot = false
    local function collect(container)
        if not container then
            return
        end
        for _, item in ipairs(container:GetChildren()) do
            if item:IsA("Tool") then
                local slotAttribute = item:GetAttribute("Slot") or item:GetAttribute("HotbarSlot") or item:GetAttribute("Index")
                if slotAttribute ~= nil then
                    hasExplicitSlot = true
                end
                table.insert(tools, item)
            end
        end
    end
    collect(localPlayer:FindFirstChild("Backpack"))
    if hasExplicitSlot then
        table.sort(tools, function(a, b)
            local aSlot = tonumber(a:GetAttribute("Slot") or a:GetAttribute("HotbarSlot") or a:GetAttribute("Index")) or math.huge
            local bSlot = tonumber(b:GetAttribute("Slot") or b:GetAttribute("HotbarSlot") or b:GetAttribute("Index")) or math.huge
            if aSlot ~= bSlot then
                return aSlot < bSlot
            end
            if a.LayoutOrder ~= b.LayoutOrder then
                return a.LayoutOrder < b.LayoutOrder
            end
            return a.Name < b.Name
        end)
    end
    return tools
end
