local function cancelFeatureScan(featureKey)
    performanceState.featureScanTokens[featureKey] = (performanceState.featureScanTokens[featureKey] or 0) + 1
end

local function beginFeatureScan(featureKey, sourceProvider, callback, enabledPredicate)
    cancelFeatureScan(featureKey)
    local token = performanceState.featureScanTokens[featureKey]
    local batchSize = performanceState.featureScanBatchSize

    task.spawn(function()
        local source = {}
        local ok = pcall(function()
            source = sourceProvider() or {}
        end)
        if not ok or type(source) ~= "table" then
            return
        end

        local index = 1
        local total = #source
        while index <= total do
            if not isRuntimeActive() then
                return
            end
            if performanceState.featureScanTokens[featureKey] ~= token then
                return
            end
            if enabledPredicate and not enabledPredicate() then
                return
            end

            local endIndex = math.min(index + batchSize - 1, total)
            for i = index, endIndex do
                callback(source[i])
            end
            index = endIndex + 1
            task.wait()
        end
    end)
end

