        end
    end
    return options[1] or "Any"
end

local function closeGiftDropdown(control)
    if not control then
        return
    end
    control.isOpen = false
    control.dropdownFrame.Visible = false
    control.card.Size = UDim2.new(1, 0, 0, 124)
    control.arrowLabel.Text = "v"
end

local function openGiftDropdown(control)
    for _, dropdown in ipairs(giftDropdownControls) do
        if dropdown ~= control then
            closeGiftDropdown(dropdown)
        end
    end
    control.isOpen = true
    control.dropdownFrame.Visible = true
    control.card.Size = UDim2.new(1, 0, 0, 234)
    control.arrowLabel.Text = "^"
end

local function rebuildGiftDropdownOptions(control, options, selectedValue, normalizeFn, onSelect)
    control.options = options or { "Any" }
    for _, button in ipairs(control.optionButtons) do
        if button and button.Parent then
            button:Destroy()
        end
    end
    control.optionButtons = {}

    local selectedToken = normalizeFn(selectedValue or "Any")
    for index, option in ipairs(control.options) do
        local optionButton = Instance.new("TextButton")
        optionButton.Name = "Option" .. tostring(index)
        optionButton.Size = UDim2.new(1, 0, 0, 26)
        optionButton.BackgroundColor3 = theme.panel
        optionButton.TextColor3 = theme.text
        optionButton.TextSize = 12
        optionButton.Font = Enum.Font.Gotham
        optionButton.TextXAlignment = Enum.TextXAlignment.Left
        optionButton.Text = tostring(option)
        optionButton.Parent = control.dropdownScroll
        addCorner(optionButton, 6)

        local isSelected = normalizeFn(option) == selectedToken
        if isSelected then
            optionButton.BackgroundColor3 = Color3.fromRGB(31, 72, 111)
            optionButton.TextColor3 = theme.text
        else
            setButtonHover(optionButton, theme.panel, theme.panelSoft)
        end

        optionButton.Activated:Connect(function()
            onSelect(option)
            closeGiftDropdown(control)
        end)
        table.insert(control.optionButtons, optionButton)
    end
end

local function closeAllGiftDropdowns()
    for _, dropdown in ipairs(giftDropdownControls) do
        closeGiftDropdown(dropdown)
    end
end

