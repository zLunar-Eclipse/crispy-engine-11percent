}

function isBlockedEnchantName(value)
    local token = normalizeEnchantToken(value)
    if token == "" then
        return true
    end
    return blockedEnchantTokens[token] == true
end

local function isLikelyEnchantName(value)
    if type(value) ~= "string" then
        return false
    end
    local cleaned = value:gsub("^%s+", ""):gsub("%s+$", "")
    if cleaned == "" then
        return false
    end
    if #cleaned > 32 then
        return false
    end
    if cleaned:find("[%c]") then
        return false
    end
    if cleaned:find("[%.!,:;]") then
        return false
    end
    local wordCount = 0
    for _ in cleaned:gmatch("%S+") do
        wordCount = wordCount + 1
    end
    if wordCount > 4 then
        return false
    end
    if isBlockedEnchantName(cleaned) then
        return false
    end
    return true
end

local enchantLookupCache = {
    byNumber = {},
    byToken = {},
    loaded = false
}

local function buildEnchantLookupCache()
    if enchantLookupCache.loaded then
        return enchantLookupCache
    end
    enchantLookupCache.loaded = true
    enchantLookupCache.byNumber = {}
    enchantLookupCache.byToken = {}

    local sharedLibrary = ReplicatedStorage:FindFirstChild("SharedLibrary")
    local enchantsModule = sharedLibrary and sharedLibrary:FindFirstChild("Enchants")
    if not (enchantsModule and enchantsModule:IsA("ModuleScript")) then
        return enchantLookupCache
    end

    local ok, enchantLibrary = pcall(require, enchantsModule)
    if not ok or type(enchantLibrary) ~= "table" then
        return enchantLookupCache
    end

    local visited = {}
    local nameKeys = {
        name = true,
        enchantname = true,
        displayname = true,
        title = true
    }
    local function registerDisplay(display, numericId)
        if type(display) ~= "string" then
            return
        end
        local cleaned = display:gsub("^%s+", ""):gsub("%s+$", "")
        if cleaned == "" or not isLikelyEnchantName(cleaned) then
            return
        end
        local token = normalizeEnchantToken(cleaned)
        if token ~= "" then
            enchantLookupCache.byToken[token] = cleaned
        end
        local numberId = tonumber(numericId)
        if numberId then
            enchantLookupCache.byNumber[numberId] = cleaned
        end
    end

    local function scanTable(source)
        if type(source) ~= "table" or visited[source] then
            return
        end
        visited[source] = true

        for key, value in pairs(source) do
            if type(value) == "table" then
                local numericFromKey = tonumber(key)
                local display = value.Name or value.EnchantName or value.DisplayName or value.Title
                local numericFromValue = tonumber(value.Id) or tonumber(value.EnchantId) or tonumber(value.EnchantID)
                registerDisplay(display, numericFromValue or numericFromKey)
                scanTable(value)
            elseif type(value) == "string" then
                local keyToken = type(key) == "string" and normalizeToken(key) or ""
                if nameKeys[keyToken] or tonumber(key) ~= nil then
                    registerDisplay(value, key)
                end
            end
        end
    end
    scanTable(enchantLibrary)

    return enchantLookupCache
end

local function resolveEnchantDisplay(rawValue)
    if rawValue == nil then
        return nil
    end
    if type(rawValue) == "table" then
        return resolveEnchantDisplay(rawValue.Name or rawValue.EnchantName or rawValue.DisplayName or rawValue.Title or rawValue.Id)
    end
    if type(rawValue) == "string" then
        local cleaned = rawValue:gsub("^%s+", ""):gsub("%s+$", "")
        if cleaned == "" then
            return nil
        end
        if tonumber(cleaned) == nil then
            return cleaned
        end
        rawValue = tonumber(cleaned)
    end
    local numericValue = tonumber(rawValue)
    if numericValue == nil then
        return nil
    end
    local lookup = buildEnchantLookupCache()
    return lookup.byNumber[numericValue]
end

local function parseBoolean(value)
    if type(value) == "boolean" then
        return value
    end
    if type(value) == "number" then
        return value ~= 0
    end
    if type(value) == "string" then
        local lowered = normalizeToken(value)
        if lowered == "true" or lowered == "1" or lowered == "yes" then
            return true
        end
        if lowered == "false" or lowered == "0" or lowered == "no" then
            return false
        end
    end
    return nil
end

local function resolveRarityName(rawValue)
    if rawValue == nil then
        return nil
    end

    if type(rawValue) == "string" and tonumber(rawValue) == nil and rawValue ~= "" then
        return rawValue
    end

