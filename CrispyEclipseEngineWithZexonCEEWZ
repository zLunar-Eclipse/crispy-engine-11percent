local supportLoopState = {
    started = false,
    lastBoostBuyAt = 0,
    lastBoostUseAt = 0,
    lastGiftDropAt = 0,
    lastAscenderUpgradeAt = 0
}

-- Background support loop for auto gift dropping + boost actions.
local function startSupportLoops()
    if supportLoopState.started then
        return
    end
    supportLoopState.started = true

    task.spawn(function()
        while isRuntimeActive() do
            local now = os.clock()
            local giftDelay = getGiftDropLoopDelay()
            if _G.AutoDropGiftSwords and now - supportLoopState.lastGiftDropAt >= giftDelay then
                supportLoopState.lastGiftDropAt = now
                pcall(function()
                    dropMatchingGiftSwordsOnce()
                end)
                now = os.clock()
            end

            local delay = getBoostActionDelay()
            if _G.AutoBuyAllBoosts and now - supportLoopState.lastBoostBuyAt >= delay then
                supportLoopState.lastBoostBuyAt = now
                pcall(function()
                    buyAllBoostsOnce()
                end)
            end
            if _G.AutoUseAllBoosts and now - supportLoopState.lastBoostUseAt >= delay then
                supportLoopState.lastBoostUseAt = now
                pcall(function()
                    useAllBoostsOnce()
                end)
            end
            local ascenderDelay = math.max(getSupportLoopDelay(), 0.25)
            if _G.AutoUpgradeAscender and now - supportLoopState.lastAscenderUpgradeAt >= ascenderDelay then
                supportLoopState.lastAscenderUpgradeAt = now
                pcall(function()
                    upgradeSelectedAscenderOnce()
                end)
            end

            local loopDelay = getSupportLoopDelay()
            if _G.AutoDropGiftSwords then
                loopDelay = math.min(loopDelay, giftDelay)
            end
            if _G.AutoUpgradeAscender then
                loopDelay = math.min(loopDelay, 0.25)
            end
            if loopDelay < 0.0001 then
                loopDelay = 0.0001
            end
            task.wait(loopDelay)
        end
    end)
end

pcall(startSupportLoops)

