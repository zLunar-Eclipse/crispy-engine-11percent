    local rarity = rarities and rarities:FindFirstChild(tostring(rawValue))
    local rarityName = rarity and rarity:FindFirstChild("RarityName")
    if rarityName and rarityName:IsA("StringValue") and rarityName.Value ~= "" then
        return rarityName.Value
    end

    return tostring(rawValue)
end

local function resolveMoldName(rawValue)
    if rawValue == nil then
        return nil
    end

    if type(rawValue) == "string" and tonumber(rawValue) == nil and rawValue ~= "" then
        return rawValue
    end

