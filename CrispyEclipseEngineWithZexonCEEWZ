local function updateCullAndDeadVisibility()
    local cullDistant = _G.PerfCullDistant == true
    local hideDeadMobs = _G.PerfHideDeadMobs == true
    if not cullDistant and not hideDeadMobs then
        clearTouchedCullParts()
        performanceState.nextVisibilityUpdateAt = 0
        performanceState.nextDeadMobVisibilityUpdateAt = 0
        performanceState.cullIterationKey = nil
        return
    end

    local now = os.clock()
    local minInterval = cullDistant and 0.5 or 1.0
    if now < performanceState.nextVisibilityUpdateAt then
        return
    end
    performanceState.nextVisibilityUpdateAt = now + minInterval

    local hrp = getHumanoidRootPart()
    local cullDistance = getPerfCullDistance()
    local mobsFolder = getMobsFolder()
    local character = localPlayer.Character

    if cullDistant and not hrp and not hideDeadMobs then
        clearTouchedCullParts()
        return
    end

    if cullDistant then
        ensureCullCandidates()
        local key = performanceState.cullIterationKey
        local processed = 0
        while processed < performanceState.cullBatchSize do
            if key ~= nil and performanceState.cullCandidates[key] == nil then
                key = nil
            end
            key = next(performanceState.cullCandidates, key)
            if key == nil then
                break
            end
            applyCullVisibilityToPart(key, true, false, hrp, cullDistance, mobsFolder, character)
            processed = processed + 1
        end
        performanceState.cullIterationKey = key
        if hideDeadMobs and now >= performanceState.nextDeadMobVisibilityUpdateAt then
            performanceState.nextDeadMobVisibilityUpdateAt = now + 1.3
            applyDeadMobVisibility(mobsFolder, hrp, cullDistance, character)
        end
        return
    end

    for part in pairs(performanceState.touchedCullParts) do
        if not isPartFromDeadMob(part, mobsFolder) then
            if part and part.Parent then
                pcall(function()
                    part.LocalTransparencyModifier = 0
                end)
            end
            performanceState.touchedCullParts[part] = nil
        end
    end

    if not mobsFolder then
        return
    end

    applyDeadMobVisibility(mobsFolder, hrp, cullDistance, character)
end

local function stopAnimationsInContainer(container, character)
    if not container then
        return
    end
    for _, descendant in ipairs(container:GetDescendants()) do
        if descendant:IsA("Animator") then
            local model = descendant:FindFirstAncestorOfClass("Model")
            if not (character and model == character) then
                local tracks = descendant:GetPlayingAnimationTracks()
                for _, track in ipairs(tracks) do
                    pcall(function()
                        track:Stop(0)
                    end)
                end
            end
        end
    end
end

local function stopNonLocalAnimations()
    local character = localPlayer.Character
    local mobsFolder = getMobsFolder()
    if mobsFolder then
        stopAnimationsInContainer(mobsFolder, character)
        return
    end
    stopAnimationsInContainer(workspace, character)
end

