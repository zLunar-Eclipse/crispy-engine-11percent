        orderedGiftRarityIndex[aliasToken] = targetIndex
        orderedGiftRarityDisplayByToken[aliasToken] = orderedGiftRarityDisplayByToken[targetToken] or targetToken
    end
end

local function getGiftFilterOptionSnapshot()
    local rarityMap = { [normalizeRarityToken("Any")] = "Any" }
    local moldMap = { [normalizeMoldToken("Any")] = "Any" }
    local enchantMap = { [normalizeToken("Any")] = "Any" }

    local function rarityDisplayFormatter(cleaned, normalized)
        if normalized == "any" then
            return "Any"
        end
        return orderedGiftRarityDisplayByToken[normalized] or stripTierVariantSuffix(cleaned)
    end

    local function moldDisplayFormatter(cleaned, normalized)
        if normalized == "any" then
            return "Any"
        end
        return stripTierVariantSuffix(cleaned)
    end

    local function addOption(mapTable, display, normalizeFn, displayFormatter)
        if type(display) ~= "string" then
            return
        end
        local cleaned = display:gsub("^%s+", ""):gsub("%s+$", "")
        if cleaned == "" then
            return
        end
        if normalizeFn == normalizeEnchantToken then
            if not isLikelyEnchantName(cleaned) or isBlockedEnchantName(cleaned) then
                return
            end
        end
        local normalized = normalizeFn(cleaned)
        if normalized == "" then
            return
        end
        local finalDisplay = cleaned
        if type(displayFormatter) == "function" then
            finalDisplay = displayFormatter(cleaned, normalized)
        end
        mapTable[normalized] = finalDisplay
    end

    local rarities = ReplicatedStorage:FindFirstChild("Rarities")
    if rarities then
        for _, rarity in ipairs(rarities:GetChildren()) do
            local rarityName = rarity:FindFirstChild("RarityName")
            local display = rarityName and rarityName:IsA("StringValue") and rarityName.Value or rarity.Name
            addOption(rarityMap, display, normalizeRarityToken, rarityDisplayFormatter)
        end
    end

    local allMolds = ReplicatedStorage:FindFirstChild("AllMolds")
    if allMolds then
        for _, mold in ipairs(allMolds:GetChildren()) do
            local moldName = mold:FindFirstChild("MoldName")
            local display = moldName and moldName:IsA("StringValue") and moldName.Value or mold.Name
            addOption(moldMap, display, normalizeMoldToken, moldDisplayFormatter)
        end
    end

    local swordEntries = getCurrentGiftSwordEntries()
    for _, entry in ipairs(swordEntries) do
        if entry.rarityName and entry.rarityName ~= "" then
            addOption(rarityMap, entry.rarityName, normalizeRarityToken, rarityDisplayFormatter)
        end
        if entry.moldName and entry.moldName ~= "" then
            addOption(moldMap, entry.moldName, normalizeMoldToken, moldDisplayFormatter)
        end
        for normalized, _ in pairs(entry.enchantNormalized or {}) do
            if enchantMap[normalized] == nil then
                for _, display in ipairs(entry.enchantDisplay or {}) do
                    if normalizeEnchantToken(display) == normalized then
                        addOption(enchantMap, display, normalizeEnchantToken)
                        break
                    end
                end
            end
        end
    end

    local function mapToSortedList(sourceMap, normalizeFn, orderMap)
        local list = {}
        for _, display in pairs(sourceMap) do
            table.insert(list, display)
        end
        table.sort(list, function(a, b)
            local aAny = normalizeToken(a) == "any"
            local bAny = normalizeToken(b) == "any"
            if aAny ~= bAny then
                return aAny
            end
            local left = normalizeFn(a)
            local right = normalizeFn(b)
            local leftOrder = orderMap and orderMap[left]
            local rightOrder = orderMap and orderMap[right]
            if leftOrder ~= nil or rightOrder ~= nil then
                if leftOrder == nil then
                    return false
                end
                if rightOrder == nil then
                    return true
                end
                if leftOrder ~= rightOrder then
                    return leftOrder < rightOrder
                end
            end
            if left == right then
                return tostring(a) < tostring(b)
            end
            return left < right
        end)
        return list
    end

    return {
        rarity = mapToSortedList(rarityMap, normalizeRarityToken, orderedGiftRarityIndex),
        mold = mapToSortedList(moldMap, normalizeMoldToken),
        enchant = mapToSortedList(enchantMap, normalizeEnchantToken),
        cracked = { "Any", "Cracked Only", "Not Cracked" },
        swordCount = #swordEntries
    }
end

local function hasTableEntries(value)
    if type(value) ~= "table" then
        return false
    end
    for _ in pairs(value) do
        return true
    end
    return false
end

local function normalizeGiftSelectionSet(source, normalizeFn)
    local selected = {}
    local anySelected = false

    local function register(rawValue)
        local token = normalizeFn(rawValue)
        if token == "" then
            return
        end
        if token == "any" then
            anySelected = true
            return
        end
        selected[token] = true
    end

    if type(source) == "table" then
        for key, value in pairs(source) do
            if type(key) == "string" and value == true then
                register(key)
            elseif type(value) == "string" or type(value) == "number" then
                register(value)
            elseif type(key) == "number" and value == true then
                register(key)
            end
            if anySelected then
                break
            end
        end
    elseif source ~= nil then
        register(source)
    end

    if anySelected or next(selected) == nil then
        return { any = true }
    end
    return selected
end

local function pickGiftSelectionDisplay(options, selectionSet, normalizeFn)
    if not options then
        return selectionSet.any and "Any" or ""
    end
    if selectionSet.any then
        for _, option in ipairs(options) do
            if normalizeFn(option) == "any" then
                return option
            end
        end
        return "Any"
    end

    for _, option in ipairs(options) do
        local token = normalizeFn(option)
        if token ~= "any" and selectionSet[token] then
            return option
        end
    end

    for token in pairs(selectionSet) do
        if token ~= "any" then
            return token
        end
    end
    return "Any"
end

local function describeGiftSelection(selectionSet, options, normalizeFn)
    if selectionSet.any then
        return "Any"
    end

    local labels = {}
    if type(options) == "table" then
        for _, option in ipairs(options) do
            local token = normalizeFn(option)
            if token ~= "any" and selectionSet[token] then
                table.insert(labels, tostring(option))
            end
        end
    end
    if #labels == 0 then
        for token in pairs(selectionSet) do
            if token ~= "any" then
                table.insert(labels, token)
            end
        end
        table.sort(labels)
    end

    if #labels <= 2 then
        return table.concat(labels, ", ")
    end
    return tostring(#labels) .. " selected"
end

local function getGiftFilterSelectionSet(selectionKey, legacyValue, normalizeFn)
    local source = hasTableEntries(_G[selectionKey]) and _G[selectionKey] or legacyValue
    local selectionSet = normalizeGiftSelectionSet(source, normalizeFn)
    _G[selectionKey] = selectionSet
    return selectionSet
end

local function buildGiftFilterDropdownDefaults(selectionKey, legacyValue, options, normalizeFn)
    local selectionSet = getGiftFilterSelectionSet(selectionKey, legacyValue, normalizeFn)
    if selectionSet.any then
        return { pickGiftSelectionDisplay(options, selectionSet, normalizeFn) }, selectionSet
    end

    local defaults = {}
    for _, option in ipairs(options or {}) do
        local token = normalizeFn(option)
        if token ~= "any" and selectionSet[token] then
            table.insert(defaults, option)
        end
    end

    if #defaults == 0 then
        selectionSet = { any = true }
        _G[selectionKey] = selectionSet
        defaults = { pickGiftSelectionDisplay(options, selectionSet, normalizeFn) }
    end
    return defaults, selectionSet
end

local function setGiftFilterSingleSelection(selectionKey, legacyKey, value, normalizeFn)
