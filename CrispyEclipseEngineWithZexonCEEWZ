    local function computeSliderRounding(step)
        local value = math.abs(tonumber(step) or 1)
        if value >= 1 then
            return 0
        end
        local text = string.format("%.8f", value):gsub("0+$", ""):gsub("%.$", "")
        local decimals = text:match("%.(%d+)")
        return decimals and #decimals or 0
    end

    local function applyParagraphDescription(paragraph, description)
        local text = tostring(description or "")
        if type(paragraph) ~= "table" then
            return
        end

        if type(paragraph.SetDesc) == "function" and pcall(paragraph.SetDesc, paragraph, text) then
            return
        end
        if type(paragraph.SetDescription) == "function" and pcall(paragraph.SetDescription, paragraph, text) then
            return
        end
        if type(paragraph.SetContent) == "function" and pcall(paragraph.SetContent, paragraph, text) then
            return
        end
        if type(paragraph.Set) == "function" and pcall(paragraph.Set, paragraph, text) then
            return
        end

        pcall(function()
            paragraph.Content = text
        end)
    end

    local function wrapParagraph(paragraph)
        local wrapper = {}
        function wrapper:SetDesc(description)
            applyParagraphDescription(paragraph, description)
        end
        function wrapper:SetDescription(description)
            applyParagraphDescription(paragraph, description)
        end
        function wrapper:Set(description)
            applyParagraphDescription(paragraph, description)
        end
        return wrapper
    end

    local function buildFluentTabWrapper(rawTab)
        local tabWrapper = {}
        tabWrapper.__rawTab = rawTab

        function tabWrapper:Section(options)
            local title = tostring(options and options.Title or "")
            local paragraph = nil
            pcall(function()
                if type(rawTab.AddSection) == "function" then
                    paragraph = rawTab:AddSection(title)
                elseif type(rawTab.AddParagraph) == "function" then
                    paragraph = rawTab:AddParagraph({
                        Title = title,
                        Content = ""
                    })
                end
            end)
            return wrapParagraph(paragraph or {})
        end

        function tabWrapper:Space()
            -- Keep this as a no-op; Fluent already has sufficient spacing.
        end

        function tabWrapper:Paragraph(options)
            local paragraph = nil
            pcall(function()
                paragraph = rawTab:AddParagraph({
                    Title = tostring(options and options.Title or ""),
                    Content = tostring((options and (options.Desc or options.Content)) or "")
                })
            end)
            return wrapParagraph(paragraph or {})
        end

        function tabWrapper:Button(options)
            local callback = options and options.Callback
            local button = nil
            pcall(function()
                button = rawTab:AddButton({
                    Title = tostring(options and options.Title or "Button"),
                    Description = options and (options.Desc or options.Description) or nil,
                    Callback = function()
                        if type(callback) == "function" then
                            callback()
                        end
                    end
                })
            end)
            return button
        end

        function tabWrapper:Toggle(options)
            local callback = options and options.Callback
            local toggle = nil
            pcall(function()
                toggle = rawTab:AddToggle(nextControlId("Toggle"), {
                    Title = tostring(options and options.Title or "Toggle"),
                    Description = options and (options.Desc or options.Description) or nil,
                    Default = options and options.Value == true or false
                })
            end)
            if toggle and type(toggle.OnChanged) == "function" then
                toggle:OnChanged(function(value)
                    local state = value
                    if state == nil then
                        state = toggle.Value
                    end
                    if type(callback) == "function" then
                        callback(state == true)
                    end
                end)
            end
            return toggle
        end

        function tabWrapper:Slider(options)
            local callback = options and options.Callback
            local sliderConfig = type(options and options.Value) == "table" and options.Value or {}
            local minValue = tonumber(sliderConfig.Min) or 0
            local maxValue = tonumber(sliderConfig.Max) or 100
            if maxValue < minValue then
                minValue, maxValue = maxValue, minValue
            end
            local step = tonumber(options and options.Step) or 1
            local defaultValue = tonumber(sliderConfig.Default)
            if defaultValue == nil then
                defaultValue = minValue
            end
            defaultValue = math.clamp(defaultValue, minValue, maxValue)

            local slider = nil
            pcall(function()
                slider = rawTab:AddSlider(nextControlId("Slider"), {
                    Title = tostring(options and options.Title or "Slider"),
                    Description = options and (options.Desc or options.Description) or nil,
                    Default = defaultValue,
                    Min = minValue,
                    Max = maxValue,
                    Rounding = computeSliderRounding(step),
                    Callback = function(value)
                        if type(callback) == "function" then
                            callback(value)
                        end
                    end
                })
            end)
            return slider
        end

        function tabWrapper:Dropdown(options)
            local callback = options and options.Callback
            local values = type(options and options.Values) == "table" and options.Values or {}
            local isMulti = options and options.Multi == true or false
            local defaultValue = nil
            if isMulti then
                defaultValue = normalizeSelectionList(options and options.Value, values)
            else
                defaultValue = normalizeSingleSelection(options and options.Value)
            end

            local dropdown = nil
            pcall(function()
                dropdown = rawTab:AddDropdown(nextControlId("Dropdown"), {
                    Title = tostring(options and options.Title or "Dropdown"),
                    Description = options and (options.Desc or options.Description) or nil,
                    Values = values,
                    Multi = isMulti,
                    Default = defaultValue
                })
            end)

            if dropdown and type(dropdown.OnChanged) == "function" then
                dropdown:OnChanged(function(value)
                    if type(callback) ~= "function" then
                        return
                    end
                    if isMulti then
                        callback(normalizeSelectionList(value, values))
                    else
                        callback(normalizeSingleSelection(value) or "")
                    end
                end)
            end

            local dropdownWrapper = {}
            function dropdownWrapper:Refresh(nextValues)
                values = type(nextValues) == "table" and nextValues or {}
                if not dropdown then
                    return
                end
                if type(dropdown.SetValues) == "function" and pcall(dropdown.SetValues, dropdown, values) then
                    return
                end
                pcall(function()
                    if type(dropdown.Refresh) == "function" then
                        dropdown:Refresh(values)
                    end
                end)
            end
            function dropdownWrapper:Select(selection)
                if not dropdown then
                    return
                end

                local prepared = selection
                if isMulti then
                    prepared = convertMultiSelectionToMap(normalizeSelectionList(selection, values))
                else
                    prepared = normalizeSingleSelection(selection)
                end

                if type(dropdown.SetValue) == "function" and pcall(dropdown.SetValue, dropdown, prepared) then
                    return
                end
                pcall(function()
                    if type(dropdown.Set) == "function" then
                        dropdown:Set(prepared)
                    end
                end)
            end
            function dropdownWrapper:Set(selection)
                self:Select(selection)
            end

            return dropdownWrapper
        end

        return tabWrapper
    end

