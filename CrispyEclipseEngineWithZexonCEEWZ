        return false
    end
    local inDungeonSession = inDungeon()
    local hrp = getHumanoidRootPart()
    local towerBounds = inDungeonSession and getDungeonTowerBounds() or nil
    for _, mob in ipairs(mobs:GetChildren()) do
        if isMobAlive(mob) then
            if not inDungeonSession then
                return true
            end
            local root = getMobRoot(mob)
            if isMobRelevantToActiveDungeon(mob, root, hrp, towerBounds) then
                return true
            end
        end
    end
    return false
end
local function findNearestMob(predicate)
    local mobs = getMobsFolder()
    if not mobs then
        return nil
    end
    local hrp = getHumanoidRootPart()
    local inDungeonSession = inDungeon()
    local towerBounds = inDungeonSession and getDungeonTowerBounds() or nil
    local bestMob = nil
    local bestDistance = math.huge
    for _, mob in ipairs(mobs:GetChildren()) do
        if isMobAlive(mob) and predicate(mob) then
            local root = getMobRoot(mob)
            if (not inDungeonSession) or isMobRelevantToActiveDungeon(mob, root, hrp, towerBounds) then
                if not hrp then
                    return mob
                end
                local distance = root and (hrp.Position - root.Position).Magnitude or math.huge
                if distance < bestDistance then
                    bestDistance = distance
                    bestMob = mob
                end
            end
        end
    end
    return bestMob
end
local function isPriorityMobName(name)
