local function showNotification(message, duration)
    if not screenGui or not screenGui.Parent or not notificationFrame.Parent then
        return
    end

    notificationToken = notificationToken + 1
    local token = notificationToken

    notificationLabel.Text = tostring(message or "")
    notificationFrame.Visible = true
    notificationFrame.Position = UDim2.new(1, 320, 1, -14)
    TweenService:Create(notificationFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(1, -14, 1, -14)
    }):Play()

    task.spawn(function()
        task.wait(duration or 2.3)
        if token ~= notificationToken then
            return
        end
        if not screenGui or not screenGui.Parent or not notificationFrame.Parent then
            return
        end

        local hideTween = TweenService:Create(notificationFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(1, 320, 1, -14)
        })
        hideTween:Play()
        hideTween.Completed:Wait()

        if token == notificationToken then
            notificationFrame.Visible = false
        end
    end)
end

