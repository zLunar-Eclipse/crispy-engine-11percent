    local function formatWholeNumber(value)
        local numeric = math.floor((tonumber(value) or 0) + 0.5)
        local text = tostring(numeric)
        local sign = ""
        if string.sub(text, 1, 1) == "-" then
            sign = "-"
            text = string.sub(text, 2)
        end
        while true do
            local replaced, count = text:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
            text = replaced
            if count == 0 then
                break
            end
        end
        return sign .. text
    end

