local function applyEffectsOptimizationToInstance(instance)
    local effectsFolder = performanceState.effectsFolder
    if not (effectsFolder and effectsFolder.Parent) then
        effectsFolder = workspace:FindFirstChild("Effects")
        performanceState.effectsFolder = effectsFolder
    end
    if not effectsFolder or not instance:IsDescendantOf(effectsFolder) then
