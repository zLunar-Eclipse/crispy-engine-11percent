local function isMobRelevantToActiveDungeon(mob, root, hrp, towerBounds)
    if not inDungeon() then
        return true
    end
    if not root then
        return isLikelyBossName(mob and mob.Name)
    end
    local rootPosition = root.Position
    if towerBounds and isPositionInsideBounds(rootPosition, towerBounds, DUNGEON_MOB_BOUNDS_PADDING) then
        return true
    end
    if hrp then
        local distance = (hrp.Position - rootPosition).Magnitude
        local radius = isLikelyBossName(mob and mob.Name) and DUNGEON_BOSS_FALLBACK_RADIUS or DUNGEON_MOB_FALLBACK_RADIUS
        if distance <= radius then
            return true
        end
    end
    return false
end
local function hasAnyMobsAlive()
