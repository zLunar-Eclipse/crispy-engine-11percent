        local utilities = sharedModules and sharedModules:FindFirstChild("Utilities")
        local shortModule = utilities and utilities:FindFirstChild("Short")
        if shortModule and shortModule:IsA("ModuleScript") then
            local ok, formatter = pcall(require, shortModule)
            if ok and type(formatter) == "function" then
                shortNumberFormatter = formatter
            end
        end
        return shortNumberFormatter
    end

    local function formatMetricNumber(value)
        local function normalizeRateSuffixCase(text)
            if type(text) ~= "string" then
                return text
            end
            return text:gsub("sVg", "SVg")
        end

        local numeric = tonumber(value) or 0
        if numeric ~= numeric or numeric == math.huge or numeric == -math.huge then
            return "0"
        end

        local formatter = getGameShortNumberFormatter()
        if formatter then
            local ok, formatted = pcall(function()
                return formatter(numeric, true, true)
            end)
            if ok and type(formatted) == "string" and formatted ~= "" then
                return normalizeRateSuffixCase(formatted)
            end
        end

        return normalizeRateSuffixCase(formatWholeNumber(numeric))
    end

