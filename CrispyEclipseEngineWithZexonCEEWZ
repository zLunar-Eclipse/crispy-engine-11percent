local function normalizeToken(value)
    local token = string.lower(tostring(value or ""))
    token = token:gsub("_", " ")
    token = token:gsub("%s+", " ")
    token = token:gsub("^%s+", "")
    token = token:gsub("%s+$", "")
    return token
end

local function stripTierVariantSuffix(value)
    local cleaned = tostring(value or "")
    cleaned = cleaned:gsub("^%s+", ""):gsub("%s+$", "")
    cleaned = cleaned:gsub("%s*[%+%-]%s*%d+$", "")
    cleaned = cleaned:gsub("%s*[%+%-]%s*[ivxlcdm]+$", "")
    cleaned = cleaned:gsub("%s*%(%s*[%+%-]?%d+%s*%)$", "")
    cleaned = cleaned:gsub("%s*%[%s*[%+%-]?%d+%s*%]$", "")
    cleaned = cleaned:gsub("%s*[%+%-]+$", "")
    cleaned = cleaned:gsub("%s+", " ")
    cleaned = cleaned:gsub("^%s+", ""):gsub("%s+$", "")
    return cleaned
end

local function normalizeRarityToken(value)
    local token = normalizeToken(stripTierVariantSuffix(value))
    if token == "isotopic" then
        return "istopic"
    end
    if token == "absolute" then
        return "absolulute"
    end
    if token == "requiem" then
        return "reqium"
    end
    if token == "viridian" then
        return "virdian"
    end
    if token == "cybernetic" then
        return "cybernotic"
    end
    if token == "paradoxical" then
        return "paradoxal"
    end
    return token
end

local function normalizeMoldToken(value)
    return normalizeToken(stripTierVariantSuffix(value))
end

local function normalizeEnchantToken(value)
    local token = normalizeToken(value)
    token = token:gsub("^%[%s*[\"']?", "")
    token = token:gsub("[\"']?%s*[,]%s*[%+%-]?%d+%s*%]$", "")
    token = token:gsub("^enchant%s*%d*%s*[:%-]?%s*", "")
    token = token:gsub("%s*[%+%-]?%s*lvl%s*%.?%s*%d+$", "")
    token = token:gsub("%s*[%+%-]?%s*level%s*%.?%s*%d+$", "")
    token = token:gsub("%s*[%+%-]?%s*%d+$", "")
    token = token:gsub("%s+[ivxlcdm]+$", "")
    token = token:gsub("%+", " ")
    token = token:gsub("[^%w%s]", " ")
    token = token:gsub("%s+", "")
    token = token:gsub("^%d+", "")
    token = token:gsub("%d+$", "")
    return token
end

blockedEnchantTokens = blockedEnchantTokens or {
    ["any"] = true,
