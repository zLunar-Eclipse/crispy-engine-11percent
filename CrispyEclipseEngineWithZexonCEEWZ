local function rememberOriginalProperty(instance, propertyName)
    if not instance then
        return
    end

    local bucket = performanceState.originals[instance]
    if not bucket then
        bucket = {}
        performanceState.originals[instance] = bucket
    end
    if bucket[propertyName] ~= nil then
        return
    end

    local ok, value = pcall(function()
        return instance[propertyName]
    end)
    if ok then
        bucket[propertyName] = value
    end
end

local function setFeatureProperty(featureBucket, instance, propertyName, value)
    if not instance then
        return
    end

    local ok, currentValue = pcall(function()
        return instance[propertyName]
    end)
    if not ok then
        return
    end
    if currentValue == value then
        return
    end

    rememberOriginalProperty(instance, propertyName)
    local setOk = pcall(function()
        instance[propertyName] = value
    end)
    if not setOk then
        return
    end

    local tracked = featureBucket[instance]
    if not tracked then
        tracked = {}
        featureBucket[instance] = tracked
    end
    tracked[propertyName] = true
end

local function restoreFeatureProperties(featureBucket)
    for instance, properties in pairs(featureBucket) do
        if instance then
            local originals = performanceState.originals[instance]
            for propertyName in pairs(properties) do
                if originals and originals[propertyName] ~= nil then
                    pcall(function()
                        instance[propertyName] = originals[propertyName]
                    end)
                    originals[propertyName] = nil
                end
            end
            if originals and next(originals) == nil then
                performanceState.originals[instance] = nil
            end
        end
        featureBucket[instance] = nil
    end
end

