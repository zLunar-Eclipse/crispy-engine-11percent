local function getDungeonTowerBounds()
    local cached = dungeonState.towerBounds
    if cached and cached.tower and cached.tower.Parent then
        return cached
    end
    local tower = getHalloweenTower()
    if not tower then
        dungeonState.towerBounds = nil
        return nil
    end
    local minVec = nil
    local maxVec = nil
    for _, descendant in ipairs(tower:GetDescendants()) do
        if descendant:IsA("BasePart") then
            local pos = descendant.Position
            if not minVec then
                minVec = pos
                maxVec = pos
            else
                minVec = Vector3.new(
                    math.min(minVec.X, pos.X),
                    math.min(minVec.Y, pos.Y),
                    math.min(minVec.Z, pos.Z)
                )
                maxVec = Vector3.new(
                    math.max(maxVec.X, pos.X),
                    math.max(maxVec.Y, pos.Y),
                    math.max(maxVec.Z, pos.Z)
                )
            end
        end
    end
    if not minVec or not maxVec then
        dungeonState.towerBounds = nil
        return nil
    end
    local bounds = {
        tower = tower,
        min = minVec,
        max = maxVec
    }
    dungeonState.towerBounds = bounds
    return bounds
end
local function isPositionInsideBounds(position, bounds, padding)
    if not position or not bounds then
        return false
    end
    local pad = tonumber(padding) or 0
    return position.X >= (bounds.min.X - pad)
        and position.X <= (bounds.max.X + pad)
        and position.Y >= (bounds.min.Y - pad)
        and position.Y <= (bounds.max.Y + pad)
        and position.Z >= (bounds.min.Z - pad)
        and position.Z <= (bounds.max.Z + pad)
end
local function isLikelyBossName(name)
    local lowered = string.lower(tostring(name or ""))
    return lowered == "bimbo the terrifier"
        or string.find(lowered, "bimbo", 1, true) ~= nil
        or string.find(lowered, "terrifier", 1, true) ~= nil
        or string.find(lowered, "boss", 1, true) ~= nil
