local function runDungeonPhase()
    if dungeonState.lootComplete then
        task.wait(0.25)
        return
    end

    if dungeonState.returnTriggered then
        if not inDungeon() then
            dungeonState.lootComplete = true
            return
        end

        local now = os.clock()
        if now >= (dungeonState.nextReturnRetryAt or 0) then
            teleportBackToGraveyard()
            dungeonState.nextReturnRetryAt = now + 1.5
        end

        task.wait(0.15)
        return
    end

    local boss = findBossMob()
    if boss then
        dungeonState.bossSeen = true
        dungeonState.bossMissingSince = nil
        dungeonState.noMobsSince = nil
        dungeonState.seenDungeonMob = true
        dungeonState.lootStartAt = nil
        fightMob(boss)
        return
    end

    local priorityMob = findPriorityMob()
    if priorityMob then
        dungeonState.bossMissingSince = nil
        dungeonState.noMobsSince = nil
        dungeonState.seenDungeonMob = true
        dungeonState.lootStartAt = nil
        fightMob(priorityMob)
        return
    end

    local nonBossMob = findAnyNonBossMob()
    if nonBossMob then
        dungeonState.bossMissingSince = nil
        dungeonState.noMobsSince = nil
        dungeonState.seenDungeonMob = true
        dungeonState.lootStartAt = nil
        fightMob(nonBossMob)
        return
    end

    if not dungeonState.noMobsSince then
        dungeonState.noMobsSince = os.clock()
    end

    local noMobsDuration = dungeonState.noMobsSince and (os.clock() - dungeonState.noMobsSince) or 0
    local dungeonDuration = os.clock() - (dungeonState.dungeonEnteredAt or os.clock())
    local canStartLoot = noMobsDuration >= 0.2 and dungeonState.bossSeen
    if not canStartLoot and dungeonDuration >= 18 and noMobsDuration >= 2.2 then
        canStartLoot = true
    end

    if canStartLoot then
        if not dungeonState.lootStartAt then
            dungeonState.lootStartAt = os.clock()
            print("[Zexon Hub] Starting chest phase.")
        end

        local openedAllChests = openDungeonChests()
        if openedAllChests then
            if not dungeonState.returnTriggered then
                dungeonState.returnTriggered = true
                dungeonState.nextReturnRetryAt = 0
                teleportBackToGraveyard()
            end
            dungeonState.lootComplete = not inDungeon()
            return
        end

        local chestPhaseDuration = dungeonState.lootStartAt and (os.clock() - dungeonState.lootStartAt) or 0
        if chestPhaseDuration >= DUNGEON_LOOT_TIMEOUT then
            warn("[Zexon Hub] Chest phase timeout; forcing return.")
            if not dungeonState.returnTriggered then
                dungeonState.returnTriggered = true
                dungeonState.nextReturnRetryAt = 0
                teleportBackToGraveyard()
            end
            dungeonState.lootComplete = not inDungeon()
        end
        return
    end

    dungeonState.lootStartAt = nil
    dungeonState.lootChestScanLogged = false
    dungeonState.lootNoChestWarned = false

    local playerEnterTrigger = getPlayerEnterTrigger()
    if playerEnterTrigger then
        teleportToPosition(playerEnterTrigger.Position)
        dungeonState.enterTriggerUsed = true
    end

    for _ = 1, 3 do
        doAttack("Dungeon")
        task.wait(0.08)
    end
end

local function runLobbyPhase()
    if not isNightWindow() then
        task.wait(0.25)
        return
    end

    local pad = getMatchmakingPad()
    local hrp = getHumanoidRootPart()
    if not pad or not hrp then
        task.wait(0.2)
        return
    end

    local distance = (hrp.Position - pad.Position).Magnitude
    if distance > 3 then
        teleportToPosition(pad.Position)
    end

    if (not inDungeon() or isForceLobbyActive()) and not hasAnyMobsAlive() then
        local refreshedHrp = getHumanoidRootPart()
        if refreshedHrp then
            local pushedDistance = (refreshedHrp.Position - pad.Position).Magnitude
            if pushedDistance > 3 then
                teleportToPosition(pad.Position)
            end
        end
    end

    task.wait(0.12)
end

local function runAutoFarmLoop()
    local hasEnteredDungeon = inDungeon() and not isForceLobbyActive()
    if hasEnteredDungeon then
        print("joined dungeon 2")
        resetDungeonState()
    end

    while shouldRunFarmLoop() and isRuntimeActive() do
        local currentlyInDungeon = inDungeon()
        local forceLobbyMode = isForceLobbyActive()
        local worldFarmEnabled = isWorldFarmEnabled()
        local worldFarmMode = getWorldFarmMode()
        _G.__ZexonWorldFarmLoopRunning = worldFarmEnabled

        if currentlyInDungeon and not forceLobbyMode and not hasEnteredDungeon then
            print("joined dungeon 2")
            hasEnteredDungeon = true
            resetDungeonState()
        end

        if worldFarmEnabled then
            if currentlyInDungeon and not forceLobbyMode then
                runDungeonPhase()
            else
                if hasEnteredDungeon and not currentlyInDungeon then
                    hasEnteredDungeon = false
                    resetDungeonState()
                end

                if worldFarmMode == "With Dungeon" and isNightWindow() then
                    runLobbyPhase()
                else
                    runWorldFarmPhase()
                end
            end
        else
            if currentlyInDungeon and not forceLobbyMode then
                runDungeonPhase()
            else
                if hasEnteredDungeon and not currentlyInDungeon then
                    hasEnteredDungeon = false
                    resetDungeonState()
                end
                runLobbyPhase()
            end
        end

        task.wait()
    end

    _G.__ZexonWorldFarmLoopRunning = false
end

