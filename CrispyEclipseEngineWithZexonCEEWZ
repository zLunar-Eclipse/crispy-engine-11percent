local function encodePersistedValue(value, depth)
    local valueType = type(value)
    if valueType == "boolean" or valueType == "number" or valueType == "string" then
        return value
    end
    if valueType ~= "table" or depth >= 6 then
        return nil
    end
    local output = {}
    for key, child in pairs(value) do
        local keyType = type(key)
        if keyType == "string" or keyType == "number" then
            local encodedChild = encodePersistedValue(child, depth + 1)
            if encodedChild ~= nil then
                output[tostring(key)] = encodedChild
            end
        end
    end
    return output
end
