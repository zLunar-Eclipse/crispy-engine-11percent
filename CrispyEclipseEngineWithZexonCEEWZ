local function coercePersistedKeepSwordSlots(savedValue)
    local normalized = {}
    if type(savedValue) ~= "table" then
        return normalized
    end
    for key, value in pairs(savedValue) do
        local slot = nil
        if value == true then
            slot = tonumber(key)
        end
        if slot == nil then
            slot = tonumber(value)
        end
        if slot and slot >= 1 and slot <= 10 then
            normalized[math.floor(slot)] = true
        end
    end
