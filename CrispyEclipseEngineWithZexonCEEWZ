end

local function getGiftIdFromAny(value)
    if value == nil then
        return nil
    end
    local text = tostring(value)
    if text == "" then
        return nil
    end
    local digits = text:match("%d+")
    if digits then
        return digits
    end
    return nil
end

local function getGiftConfigTable(entryData)
    if type(entryData) ~= "table" then
        return nil
    end

    if type(entryData.Config) == "table" then
        return entryData.Config
    end
    if type(entryData.config) == "table" then
        return entryData.config
    end
    if type(entryData.Data) == "table" and type(entryData.Data.Config) == "table" then
        return entryData.Data.Config
    end
    if type(entryData.Payload) == "table" and type(entryData.Payload.Config) == "table" then
        return entryData.Payload.Config
    end

    if entryData.Rarity ~= nil
        or entryData.Mold ~= nil
        or entryData.Cracked ~= nil
        or entryData.Enchant1 ~= nil
        or entryData.EnchantName1 ~= nil then
        return entryData
    end

    return nil
end

local function isSwordGiftData(entryData, config)
    if type(entryData) ~= "table" then
        return false
    end

    if normalizeToken(entryData._type) == "sword" then
        return true
    end

    if type(entryData.sub_type) == "table" then
        local kind = normalizeToken(entryData.sub_type[1])
        if kind == "rarity" or kind == "mold" then
            return true
        end
    end

    if type(config) ~= "table" then
        return false
    end

    if config.Rarity ~= nil
        or config.Mold ~= nil
        or config.Cracked ~= nil then
        return true
    end

    for i = 1, 8 do
        if config["Enchant" .. tostring(i)] ~= nil
            or config["Enchantment" .. tostring(i)] ~= nil
            or config["EnchantName" .. tostring(i)] ~= nil
            or config["EnchantmentName" .. tostring(i)] ~= nil then
            return true
        end
    end

    if type(config.Enchants) == "table" or type(config.Enchantments) == "table" then
        return true
    end

    return false
end

local function collectGiftEntriesRecursive(source, output, visited)
    if type(source) ~= "table" or visited[source] then
        return
    end
    visited[source] = true

    for key, value in pairs(source) do
        if type(value) == "table" then
            local giftId = getGiftIdFromAny(value.Id)
                or getGiftIdFromAny(value.ID)
                or getGiftIdFromAny(value.GiftId)
                or getGiftIdFromAny(value.GiftID)
                or getGiftIdFromAny(value.Serial)
                or getGiftIdFromAny(value.serial)
                or getGiftIdFromAny(key)

            local hasGiftMarkers = value.Sender ~= nil
                or value.GamepassId ~= nil
                or value.InfoType ~= nil
                or value._type ~= nil
                or value.sub_type ~= nil
                or value.Config ~= nil
                or value.config ~= nil
                or value.PassType ~= nil
            if giftId and hasGiftMarkers then
                output[giftId] = value
            end

            collectGiftEntriesRecursive(value, output, visited)
        end
    end
end

local function refreshGiftDataCache()
    local stats = getStatsFolder()
    local giftsValue = stats and stats:FindFirstChild("CurrentGifts")
    local raw = giftsValue and giftsValue:IsA("StringValue") and giftsValue.Value or ""

    if giftDataCache.lastRaw == raw then
        return
    end

    giftDataCache.lastRaw = raw
    giftDataCache.entries = {}
    giftDataCache.swordEntries = {}

    local decoded = safeDecodeJson(raw)
    if type(decoded) ~= "table" then
        return
    end

    local gathered = {}
    collectGiftEntriesRecursive(decoded, gathered, {})

    local entries = {}
    for id, data in pairs(gathered) do
        table.insert(entries, {
            id = tostring(id),
            data = data
        })
    end

    table.sort(entries, function(a, b)
        local numberA = tonumber(a.id)
        local numberB = tonumber(b.id)
        if numberA and numberB then
            return numberA < numberB
        end
        return tostring(a.id) < tostring(b.id)
    end)

    local swordEntries = {}
    for _, entry in ipairs(entries) do
        local config = getGiftConfigTable(entry.data)
        if isSwordGiftData(entry.data, config) then
            local rarityName = resolveRarityName(config and config.Rarity)
            local moldName = resolveMoldName(config and config.Mold)
            local crackedValue = parseBoolean(config and config.Cracked)
            if crackedValue == nil then
                crackedValue = false
            end

            local enchantMap = {}
            local function trimText(text)
                return tostring(text or ""):gsub("^%s+", ""):gsub("%s+$", "")
            end

            local function addEnchantText(display)
                if type(display) ~= "string" then
                    return
                end
                local cleaned = trimText(display)
                if cleaned == "" then
                    return
                end

                local function register(rawPart)
                    local part = trimText(rawPart)
                    if part == "" then
                        return
                    end
                    part = part:gsub("^enchant%s*%d*%s*[:%-]?%s*", "")
                    part = part:gsub("^%[%s*[\"']?", "")
                    part = part:gsub("[\"']?%s*[,]%s*[%+%-]?%d+%s*%]$", "")
                    part = trimText(part)
                    if part == "" then
                        return
                    end
                    if not isLikelyEnchantName(part) then
                        return
                    end

                    local normalized = normalizeEnchantToken(part)
                    if normalized == "" then
                        return
                    end
                    if blockedEnchantTokens[normalized] then
                        return
                    end
                    if tonumber(normalized) ~= nil then
                        return
                    end
                    if #normalized < 2 or #normalized > 36 then
                        return
                    end
                    if enchantMap[normalized] == nil then
                        enchantMap[normalized] = part
                    end
                end

                register(cleaned)
                for segment in string.gmatch(cleaned, "[^,\n\r|;/]+") do
                    register(segment)
                end
            end

            local scannedEnchantValues = {}
            local function addEnchantValue(rawValue)
                if rawValue == nil then
                    return
                end

                local valueType = type(rawValue)
                if valueType == "table" then
                    if scannedEnchantValues[rawValue] then
                        return
                    end
                    scannedEnchantValues[rawValue] = true

                    addEnchantValue(rawValue.Name)
                    addEnchantValue(rawValue.EnchantName)
                    addEnchantValue(rawValue.DisplayName)
                    addEnchantValue(rawValue.Title)
                    addEnchantValue(rawValue.Text)
                    addEnchantValue(rawValue.Value)
                    addEnchantValue(rawValue.Id)
                    addEnchantValue(rawValue.EnchantId)
                    addEnchantValue(rawValue.EnchantID)
                    for i = 1, 8 do
                        addEnchantValue(rawValue["Enchant" .. tostring(i)])
                        addEnchantValue(rawValue["EnchantName" .. tostring(i)])
                        addEnchantValue(rawValue["EnchantText" .. tostring(i)])
                        addEnchantValue(rawValue["Enchantment" .. tostring(i)])
                        addEnchantValue(rawValue["EnchantmentName" .. tostring(i)])
                        addEnchantValue(rawValue["EnchantmentText" .. tostring(i)])
                    end
                    for _, nested in pairs(rawValue) do
                        local nestedType = type(nested)
                        if nestedType == "table" or nestedType == "string" or nestedType == "number" then
                            addEnchantValue(nested)
                        end
                    end
                    return
                end

                local display = resolveEnchantDisplay(rawValue)
                if type(display) ~= "string" then
                    return
                end
                addEnchantText(display)
            end

            for i = 1, 8 do
                addEnchantValue(config and config["EnchantName" .. tostring(i)])
                addEnchantValue(config and config["EnchantmentName" .. tostring(i)])
                local valueA = config and config["Enchant" .. tostring(i)]
                local valueB = config and config["Enchantment" .. tostring(i)]
                addEnchantValue(valueA)
                addEnchantValue(valueB)
            end

            local explicitEnchantSources = {
                config,
                entry.data,
                entry.data and entry.data.Data,
                entry.data and entry.data.Config,
                entry.data and entry.data.Payload,
                entry.data and entry.data.Payload and entry.data.Payload.Config
            }
            for _, source in ipairs(explicitEnchantSources) do
                if type(source) == "table" then
                    for i = 1, 4 do
                        addEnchantValue(source["Enchant" .. tostring(i)])
                        addEnchantValue(source["EnchantName" .. tostring(i)])
                        addEnchantValue(source["EnchantText" .. tostring(i)])
                        addEnchantValue(source["enchant" .. tostring(i)])
                        addEnchantValue(source["enchant_name" .. tostring(i)])
                        addEnchantValue(source["enchant_text" .. tostring(i)])
                    end
                end
            end

            local enchantPools = {
                config and config.Enchants,
                config and config.Enchantments,
                config and config.Data and config.Data.Enchants,
                config and config.Data and config.Data.Enchantments
            }
            for _, pool in ipairs(enchantPools) do
                if type(pool) == "table" then
                    for _, enchantValue in pairs(pool) do
                        addEnchantValue(enchantValue)
                    end
                end
            end

            local scannedEnchantTables = {}
            local function scanForEnchantValues(source, parentSuggestsEnchant)
                if type(source) ~= "table" or scannedEnchantTables[source] then
                    return
                end
                scannedEnchantTables[source] = true

                for key, value in pairs(source) do
                    local keyText = type(key) == "string" and normalizeToken(key) or ""
                    local keyLooksEnchant = parentSuggestsEnchant
                        or (keyText ~= "" and (
                            string.find(keyText, "enchant", 1, true) ~= nil
                        ))

                    if keyLooksEnchant then
                        addEnchantValue(value)
                    end

                    if type(value) == "table" then
                        if keyLooksEnchant then
                            addEnchantValue(value.Name or value.EnchantName or value.DisplayName or value.Title or value.Id or value.Value)
                        end
                        scanForEnchantValues(value, keyLooksEnchant)
                    end
                end
            end
            scanForEnchantValues(config, false)
            scanForEnchantValues(entry.data, false)

            local enchantDisplay = {}
            local enchantNormalized = {}
            for normalized, display in pairs(enchantMap) do
                table.insert(enchantDisplay, display)
                enchantNormalized[normalized] = true
            end
            table.sort(enchantDisplay, function(a, b)
                return normalizeToken(a) < normalizeToken(b)
            end)

            table.insert(swordEntries, {
                id = entry.id,
                data = entry.data,
                config = config,
                rarityName = rarityName,
                moldName = moldName,
                cracked = crackedValue,
                enchantDisplay = enchantDisplay,
                enchantNormalized = enchantNormalized
            })
        end
    end

    giftDataCache.entries = entries
    giftDataCache.swordEntries = swordEntries
end

