    local shortSuffixPowerMap = nil
    local function getShortSuffixPowerMap()
        if shortSuffixPowerMap ~= nil then
            return shortSuffixPowerMap
        end

        shortSuffixPowerMap = {}
        local formatter = getGameShortNumberFormatter()
        if formatter then
            for power = 3, 306, 3 do
                local okSample, sample = pcall(function()
                    return formatter(10 ^ power, true, true)
                end)
                if okSample and type(sample) == "string" then
                    local suffix = sample:match("([A-Za-z]+)$")
                    if suffix and suffix ~= "" then
                        shortSuffixPowerMap[string.lower(suffix)] = power
                    end
                end
            end
        end

        shortSuffixPowerMap.k = shortSuffixPowerMap.k or 3
        shortSuffixPowerMap.m = shortSuffixPowerMap.m or 6
        shortSuffixPowerMap.b = shortSuffixPowerMap.b or 9
        shortSuffixPowerMap.t = shortSuffixPowerMap.t or 12
        return shortSuffixPowerMap
    end

    local function parseNumericString(text)
        if type(text) ~= "string" then
            return nil
        end
        local cleaned = text:gsub(",", ""):gsub("%s+", "")
        if cleaned == "" then
            return nil
        end

        local direct = tonumber(cleaned)
        if direct ~= nil then
            return direct
        end

        local numberPart, suffixPart = cleaned:match("^([%+%-]?%d+%.?%d*)([%a]+)$")
        if numberPart and suffixPart then
            local base = tonumber(numberPart)
            local power = getShortSuffixPowerMap()[string.lower(suffixPart)]
            if base and power then
                return base * (10 ^ power)
            end
        end

        local numericMatch = cleaned:match("[%+%-]?%d+%.?%d*")
        return tonumber(numericMatch)
    end

    local function readValueObjectMetric(valueObject)
        if not valueObject then
            return nil, nil
        end
        if valueObject:IsA("IntValue") or valueObject:IsA("NumberValue") then
            return tonumber(valueObject.Value), nil
        end
        if valueObject:IsA("StringValue") then
            local rawText = tostring(valueObject.Value or "")
            local numeric = parseNumericString(rawText)
            local cleaned = rawText:gsub("^%s+", ""):gsub("%s+$", "")
            if cleaned == "" then
                cleaned = nil
            end
            return numeric, cleaned
        end
        return nil, nil
    end

    local function readMetricAmount(metric)
        local stats = getStatsFolder()
        if not stats then
            return nil, nil
        end

        if metric.cache and metric.cache.Parent then
            local cachedValue, cachedDisplay = readValueObjectMetric(metric.cache)
            if cachedValue ~= nil then
                return cachedValue, cachedDisplay
            end
        end

        for _, alias in ipairs(metric.aliases or {}) do
            local obj = stats:FindFirstChild(alias, true)
            local value, display = readValueObjectMetric(obj)
            if value ~= nil then
                metric.cache = obj
                return value, display
            end
        end

        local bestObject = nil
        local bestValue = nil
        local bestDisplay = nil
        for _, descendant in ipairs(stats:GetDescendants()) do
            if descendant:IsA("IntValue") or descendant:IsA("NumberValue") or descendant:IsA("StringValue") then
                local lowerName = string.lower(descendant.Name)
                local matchesHint = false
                for _, hint in ipairs(metric.hints or {}) do
                    if string.find(lowerName, hint, 1, true) then
                        matchesHint = true
                        break
                    end
                end
                local isNoiseName = string.find(lowerName, "rate", 1, true)
                    or string.find(lowerName, "hour", 1, true)
                    or string.find(lowerName, "gain", 1, true)
                    or string.find(lowerName, "spent", 1, true)
                    or string.find(lowerName, "cost", 1, true)
                    or string.find(lowerName, "price", 1, true)
                    or string.find(lowerName, "per", 1, true)
                if matchesHint and not isNoiseName then
                    local value, display = readValueObjectMetric(descendant)
                    if value ~= nil and (bestValue == nil or math.abs(value) > math.abs(bestValue)) then
                        bestObject = descendant
                        bestValue = value
                        bestDisplay = display
                    end
                end
            end
        end

        if bestObject then
            metric.cache = bestObject
            return bestValue, bestDisplay
        end

        return nil, nil
    end

    local function refreshRateTracker()
        local now = os.clock()
        local updatedAny = false
        for _, metric in ipairs(rateTrackerMetrics) do
            local current, currentDisplay = readMetricAmount(metric)
            if current ~= nil then
                metric.current = current
                metric.currentDisplay = currentDisplay
                if metric.baseline == nil or current < metric.baseline then
                    metric.baseline = current
                    metric.baselineAt = now
                end

                local elapsed = math.max(now - (metric.baselineAt or now), 1)
                metric.delta = current - metric.baseline
                metric.perHour = (metric.delta / elapsed) * 3600
                updatedAny = true
            else
                metric.current = nil
                metric.currentDisplay = nil
            end
        end
        return updatedAny
    end

    local function getMetricCurrentText(metric)
        local explicitText = metric.currentDisplay
        if type(explicitText) == "string" and explicitText ~= "" then
            return explicitText:gsub("sVg", "SVg")
        end
        return formatMetricNumber(metric.current)
    end

    local function rateTrackerDetails()
