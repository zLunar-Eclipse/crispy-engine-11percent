local function collectDungeonChests()
    local tower = getHalloweenTower()
    if not tower then
        return {}
    end
    local chestList = {}
    local seen = {}
    local startModel = tower:FindFirstChild("Start")
    local startChests = startModel and startModel:FindFirstChild("Chests")
    addChestsFromFolder(startChests, chestList, seen)
    local endModule = tower:FindFirstChild("EndModule")
    local endChests = endModule and endModule:FindFirstChild("Chests")
    addChestsFromFolder(endChests, chestList, seen)
    local map = tower:FindFirstChild("Map")
    local mapFunctionalSection = map and map:FindFirstChild("MapFunctionalSection")
    if mapFunctionalSection then
        for _, section in ipairs(mapFunctionalSection:GetChildren()) do
            if section:IsA("Model") then
                addChestsFromFolder(section:FindFirstChild("Chests"), chestList, seen)
            end
        end
    end
    for _, descendant in ipairs(tower:GetDescendants()) do
        if descendant:IsA("Folder") and descendant.Name == "Chests" then
            addChestsFromFolder(descendant, chestList, seen)
        end
    end
    return chestList
end
local function shouldIgnoreChest(chest)
