local function isPartFromDeadMob(part, mobsFolder)
    if not (part and part.Parent and mobsFolder) then
        return false
    end

    local mobModel = part:FindFirstAncestorOfClass("Model")
    if not (mobModel and mobModel:IsDescendantOf(mobsFolder)) then
        return false
    end

    local humanoid = mobModel:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health <= 0
end

local function applyCullVisibilityToPart(part, cullDistant, hideDeadMobs, hrp, cullDistance, mobsFolder, character)
    if not part then
        return
    end

    if not part.Parent then
        performanceState.touchedCullParts[part] = nil
        return
    end

    if character and part:IsDescendantOf(character) then
        if performanceState.touchedCullParts[part] then
            pcall(function()
                part.LocalTransparencyModifier = 0
            end)
        end
        performanceState.touchedCullParts[part] = nil
        return
    end

    local shouldHide = false
    if cullDistant and hrp then
        local distance = (part.Position - hrp.Position).Magnitude
        if distance >= cullDistance then
            shouldHide = true
        end
    end

    if not shouldHide and hideDeadMobs then
        shouldHide = isPartFromDeadMob(part, mobsFolder)
    end

    local targetTransparency = shouldHide and 1 or 0
    local ok, currentTransparency = pcall(function()
        return part.LocalTransparencyModifier
    end)
    if ok and currentTransparency ~= targetTransparency then
        pcall(function()
            part.LocalTransparencyModifier = targetTransparency
        end)
    end

    if shouldHide then
        performanceState.touchedCullParts[part] = true
    else
        performanceState.touchedCullParts[part] = nil
    end
end

local function applyDeadMobVisibility(mobsFolder, hrp, cullDistance, character)
    if not mobsFolder then
        return
    end

    for _, mobModel in ipairs(mobsFolder:GetChildren()) do
        local humanoid = mobModel:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.Health <= 0 then
            for _, descendant in ipairs(mobModel:GetDescendants()) do
                if descendant:IsA("BasePart") then
                    applyCullVisibilityToPart(descendant, false, true, hrp, cullDistance, mobsFolder, character)
                end
            end
        end
    end
end

